---
import "../styles/global.css";
import Particles from "../components/Particles.astro";

export interface Props {
  title?: string;
  description?: string;
}
const { title = "LoveAlwaysHere", description = "Personal Blog & Tools" } = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body class="min-h-screen bg-gray-950 text-gray-100">
    <Particles />
    <div class="relative z-10">
      <nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-xl bg-gray-950/60 border-b border-gray-800/30">
        <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
          <a href="/" class="text-xl font-bold bg-gradient-to-r from-cyan-400 to-violet-500 bg-clip-text text-transparent hover:from-cyan-300 hover:to-violet-400 transition-all duration-300">✦ LoveAlwaysHere</a>
          <div class="flex items-center gap-8 text-sm">
            <a href="/" class="text-gray-400 hover:text-cyan-300 transition-all duration-300 relative group">
              首页
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-gradient-to-r from-cyan-400 to-violet-500 transition-all duration-300 group-hover:w-full"></span>
            </a>
            <a href="/blog" class="text-gray-400 hover:text-cyan-300 transition-all duration-300 relative group">
              博客
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-gradient-to-r from-cyan-400 to-violet-500 transition-all duration-300 group-hover:w-full"></span>
            </a>
            <a href="/tools" class="text-gray-400 hover:text-cyan-300 transition-all duration-300 relative group">
              工具
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-gradient-to-r from-cyan-400 to-violet-500 transition-all duration-300 group-hover:w-full"></span>
            </a>
          </div>
        </div>
      </nav>
      <main class="pt-16">
        <slot />
      </main>
      <footer class="border-t border-gray-800/20 py-8 mt-20">
        <div class="max-w-5xl mx-auto px-6 text-center text-sm text-gray-600">
          <p>&copy; 2026 LoveAlwaysHere &middot; Built with Astro &amp; Tailwind CSS</p>
        </div>
      </footer>
    </div>
  </body>
</html>