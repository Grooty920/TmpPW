---
import "../styles/global.css";
import navData from "../data/navigation.json";
import profile from "../data/profile.json";
import AnimationEffects from "../components/AnimationEffects.astro";
import InkBackground from "../components/InkBackground.astro";

import { ViewTransitions } from "astro:transitions";

export interface Props {
  title?: string;
  description?: string;
}
const { title = "小杨王子", description = "个人博客与工具集" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN" class="">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#c73e3a" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="小杨王子" />
    <link rel="icon" href="/avatar.jpg" type="image/jpeg" />
    <ViewTransitions />
    <script>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", function() {
          navigator.serviceWorker.register("/sw.js").then(function(reg) {
            console.log("SW registered:", reg.scope);
          }).catch(function(err) {
            console.log("SW registration failed:", err);
          });
        });
      }
    </script>
    <script is:inline>
      (function() {
        try {
          var theme = localStorage.getItem("theme");
          var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          if (theme === "dark" || (!theme && prefersDark)) {
            document.documentElement.classList.add("dark");
          }
        } catch(e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen antialiased">
    <!-- 渐变页眉 -->
    <div class="fixed top-0 left-0 right-0 w-full h-[500px] z-[1] pointer-events-none" style="background: linear-gradient(180deg, rgba(199,62,58,0.06) 0%, rgba(74,103,65,0.04) 40%, transparent 70%); mask-image: linear-gradient(#000, transparent 70%); -webkit-mask-image: linear-gradient(#000, transparent 70%);"></div>
    <InkBackground />
    <AnimationEffects />

    <div id="reading-progress" class="reading-progress" style="width:0%"></div>

    <header id="navbar" class="navbar-glass fixed top-0 left-0 right-0 z-50 transition-all duration-500" data-scrolled="false">
      <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
        <!-- 品牌名 -->
        <a href="/" class="brand-link text-xl font-serif font-bold tracking-wide flex items-center gap-1" style="color:var(--text-primary); font-family: 'Ma Shan Zheng', 'Noto Serif SC', cursive;"><span class="hidden sm:inline">{navData.brand}</span><span class="sm:hidden">小杨王子</span></a>

        <!-- 桌面导航 -->
        <div class="hidden md:flex items-center gap-1">
          {navData.items.map((item) => (
            <a href={item.url}
               class="nav-link relative px-3 py-2 text-sm tracking-wide rounded-md transition-all duration-300 group"
               style="color:var(--text-secondary);font-family:'LXGW WenKai','Noto Serif SC',serif;">
              <span class="nav-link-text">{item.label}</span>
              <span class="absolute bottom-0.5 left-3 w-0 h-0.5 transition-all duration-300 group-hover:w-[calc(100%-1.5rem)]" style="background-color:var(--accent)"></span>
            </a>
          ))}
          <div class="w-px h-5 mx-2" style="background-color:var(--border)"></div>
          <!-- 搜索 -->
          <a href="/search" class="nav-icon-btn relative w-9 h-9 rounded-full flex items-center justify-center transition-all duration-300 hover:bg-ink-700" style="color:var(--text-secondary)" aria-label="搜索">
            <svg class="icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
            </svg>
          </a>
          <!-- 主题切换 -->
          <button id="theme-toggle-d" class="nav-icon-btn relative w-9 h-9 rounded-full flex items-center justify-center transition-all duration-300 hover:bg-ink-700 focus:outline-none" aria-label="切换主题">
            <svg id="sun-icon-d" class="absolute icon-sm transition-all duration-500" style="color:var(--accent);opacity:1;transform:rotate(0deg) scale(1)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <svg id="moon-icon-d" class="absolute icon-sm transition-all duration-500" style="color:var(--accent);opacity:0;transform:rotate(-90deg) scale(0.5)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </button>
        </div>

        <!-- 移动端右侧 -->
        <div class="md:hidden flex items-center gap-2">
          <a href="/search" class="w-9 h-9 rounded-full flex items-center justify-center transition-all duration-300 hover:bg-ink-700" style="color:var(--text-secondary)" aria-label="搜索">
            <svg class="icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
            </svg>
          </a>
          <button id="theme-toggle-m" class="w-9 h-9 rounded-full flex items-center justify-center transition-all duration-300 hover:bg-ink-700 focus:outline-none" aria-label="切换主题">
            <svg id="sun-icon-m" class="icon-sm transition-all duration-500" style="color:var(--accent);opacity:1;transform:rotate(0deg) scale(1)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <svg id="moon-icon-m" class="absolute icon-sm transition-all duration-500" style="color:var(--accent);opacity:0;transform:rotate(-90deg) scale(0.5)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </button>
          <button id="menu-btn" class="w-9 h-9 rounded-full flex items-center justify-center transition-all duration-300 hover:bg-ink-700" style="color:var(--text-primary)" aria-label="菜单">
            <svg id="menu-icon" class="w-5 h-5 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
          </button>
        </div>
      </div>
    </header>

    <!-- 移动菜单 - 玻璃效果覆盖层 -->
    <div id="mobile-menu" class="fixed inset-0 top-16 z-40 hidden flex-col items-center justify-start gap-2 pt-12 pb-8 px-6 overflow-y-auto" style="background-color:var(--nav-bg);backdrop-filter:blur(24px) saturate(1.3);-webkit-backdrop-filter:blur(24px) saturate(1.3);border-bottom:1px solid var(--glass-border);">
      {navData.items.map((item) => (
        <a href={item.url}
           class="mobile-nav-link block w-full text-center py-4 text-base tracking-wide rounded-lg transition-all duration-300"
           style="color:var(--text-secondary);font-family:'Ma Shan Zheng','Noto Serif SC',cursive;"
           onclick="closeMobileMenu()">
          {item.label}
        </a>
      ))}
    </div>

    <main class="min-h-screen pt-20">
      <slot />
    </main>

    <!-- 回到顶部按钮 -->
    <button id="back-to-top" class="fixed z-50 flex items-center justify-center transition-all duration-500 opacity-0 pointer-events-none" style="bottom: 2rem; right: 1.5rem; width: 44px; height: 44px; border-radius: 50%; background: var(--card-bg); border: 1px solid var(--border); color: var(--text-secondary); box-shadow: 0 2px 12px var(--shadow); cursor: pointer;">
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M12 19V5M5 12l7-7 7 7"/>
      </svg>
      <svg class="progress-circle-container absolute inset-0 w-full h-full -rotate-90" viewBox="0 0 44 44">
        <circle cx="22" cy="22" r="20" fill="none" stroke="var(--border)" stroke-width="1.5"/>
        <circle id="scroll-progress" cx="22" cy="22" r="20" fill="none" stroke="var(--accent)" stroke-width="1.5" stroke-dasharray="125.6" stroke-dashoffset="125.6" stroke-linecap="round"/>
      </svg>
    </button>

    <footer class="border-t py-12 mt-24" style="border-color:var(--border)">
      <div class="max-w-5xl mx-auto px-6">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6">
          <div class="text-center md:text-left">
            <a href="/" class="text-lg font-serif font-bold tracking-wide" style="color:var(--text-primary); font-family: 'Ma Shan Zheng', 'Noto Serif SC', cursive;">{navData.brand}</a>
            <p class="text-sm mt-2" style="color:var(--text-secondary)">{profile.footer}</p>
          </div>
          <div class="flex items-center gap-6">
            <a href="https://github.com/Grooty920" target="_blank" class="w-8 h-8 rounded-full flex items-center justify-center border text-xs font-mono transition-all duration-300 hover:scale-110" style="border-color:var(--border);color:var(--text-secondary)">GH</a>
            <a href="mailto:Grooty920@gmail.com" class="w-8 h-8 rounded-full flex items-center justify-center border text-xs font-mono transition-all duration-300 hover:scale-110" style="border-color:var(--border);color:var(--text-secondary)">@</a>
            <a href="/rss.xml" class="w-8 h-8 rounded-full flex items-center justify-center border text-xs font-mono transition-all duration-300 hover:scale-110" style="border-color:var(--border);color:var(--text-secondary)" title="RSS 订阅">R</a>
          </div>
        </div>
        <div class="mt-8 text-center text-xs" style="color:var(--text-secondary)">&copy; 2026 小杨王子. 水墨 · Astro &amp; Tailwind CSS.</div>
      </div>
    </footer>

    <script>
      function setTheme(t) { document.documentElement.classList.toggle("dark", t === "dark"); localStorage.setItem("theme", t); updateIcons(t); }
      function updateIcons(theme) {
        var isDark = theme === "dark";
        [["sun-icon-d","moon-icon-d"],["sun-icon-m","moon-icon-m"]].forEach(function(p) {
          var sun = document.getElementById(p[0]), moon = document.getElementById(p[1]);
          if (!sun || !moon) return;
          sun.style.opacity = isDark ? "0" : "1"; sun.style.transform = isDark ? "rotate(90deg) scale(0.5)" : "rotate(0deg) scale(1)";
          moon.style.opacity = isDark ? "1" : "0"; moon.style.transform = isDark ? "rotate(0deg) scale(1)" : "rotate(-90deg) scale(0.5)";
        });
      }
      function toggleTheme() { setTheme(document.documentElement.classList.contains("dark") ? "light" : "dark"); }

      function initLayout() {
        var t = localStorage.getItem("theme") || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
        setTheme(t);
        // 主题切换按钮 - 桌面端和移动端独立ID
        document.getElementById("theme-toggle-d")?.addEventListener("click", toggleTheme);
        document.getElementById("theme-toggle-m")?.addEventListener("click", toggleTheme);

        // ===== 导航栏滚动效果（节流） =====
        function updateNavbar() {
          var navbar = document.getElementById("navbar");
          if (!navbar) return;
          if (window.scrollY > 10) {
            navbar.style.backgroundColor = "var(--nav-bg)";
            navbar.style.backdropFilter = "blur(24px)";
            navbar.style.boxShadow = "0 1px 3px rgba(0,0,0,0.06)";
          } else {
            navbar.style.backgroundColor = "transparent";
            navbar.style.backdropFilter = "none";
            navbar.style.boxShadow = "none";
          }
        }

        // 节流滚动监听
        var ticking = false;
        window.addEventListener("scroll", function() {
          if (!ticking) {
            requestAnimationFrame(function() {
              updateNavbar();
              updateBackToTop();
              // 阅读进度条
              var pb = document.getElementById("reading-progress");
              if (pb) {
                var dh = document.documentElement.scrollHeight - window.innerHeight;
                if (dh > 0) pb.style.width = Math.min((window.scrollY / dh) * 100, 100) + "%";
              }
              ticking = false;
            });
            ticking = true;
          }
        });
        updateNavbar();

        // ===== 当前页面高亮 =====
        var currentPath = window.location.pathname;
        document.querySelectorAll(".nav-link, .mobile-nav-link").forEach(function(link) {
          var href = link.getAttribute("href");
          if (href === currentPath || (href !== "/" && currentPath.startsWith(href))) {
            link.style.color = "var(--accent)";
            link.style.fontWeight = "600";
            var underline = link.querySelector("span:last-child");
            if (underline && underline.classList.contains("absolute")) {
              underline.style.width = "calc(100% - 1.5rem)";
            }
          }
        });

        // ===== 移动菜单交互 =====
        var mm = document.getElementById("mobile-menu");
        var mb = document.getElementById("menu-btn");
        var mi = document.getElementById("menu-icon");

        if (mb && mm) {
          mb.onclick = function() {
            toggleMobileMenu();
          };
        }

        // ESC 关闭
        document.addEventListener("keydown", function escHandler(e) {
          if (e.key === "Escape" && mm && !mm.classList.contains("hidden")) {
            closeMobileMenu();
          }
        });
      }

      // 移动菜单控制（全局函数，供内联onclick调用）
      window.closeMobileMenu = function() {
        var mm = document.getElementById("mobile-menu");
        var mi = document.getElementById("menu-icon");
        if (mm) {
          mm.classList.add("hidden");
          document.body.style.overflow = "";
        }
        if (mi) mi.innerHTML = "<path d='M3 12h18M3 6h18M3 18h18'/>";
      };

      function toggleMobileMenu() {
        var mm = document.getElementById("mobile-menu");
        var mi = document.getElementById("menu-icon");
        if (!mm) return;
        var open = mm.classList.contains("hidden");
        if (open) {
          mm.classList.remove("hidden");
          document.body.style.overflow = "hidden"; // 锁定滚动
          if (mi) mi.innerHTML = "<path d='M18 6L6 18M6 6l12 12'/>";
        } else {
          closeMobileMenu();
        }
      }

      // ===== 回到顶部按钮 =====
      var backToTop = document.getElementById("back-to-top");
      var scrollProgress = document.getElementById("scroll-progress");
      if (backToTop) {
        backToTop.addEventListener("click", function() {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      }
      
      function updateBackToTop() {
        if (!backToTop || !scrollProgress) return;
        var scrollY = window.scrollY;
        var dh = document.documentElement.scrollHeight - window.innerHeight;
        var progress = dh > 0 ? scrollY / dh : 0;
        var circumference = 125.6;
        scrollProgress.style.strokeDashoffset = circumference * (1 - progress);
        
        if (scrollY > 300) {
          backToTop.style.opacity = "1";
          backToTop.style.pointerEvents = "auto";
          backToTop.style.transform = "scale(1)";
        } else {
          backToTop.style.opacity = "0";
          backToTop.style.pointerEvents = "none";
          backToTop.style.transform = "scale(0.8)";
        }
      }
      
      // 首次加载和 ViewTransitions 导航后都执行
      function runLayout() {
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initLayout);
        } else {
          initLayout();
        }
      }
      runLayout();
      document.addEventListener('astro:page-load', runLayout);

      // ===== 全局墨滴涟漪效果 =====
      function initInkRipple() {
        document.addEventListener("click", function(e) {
          // 只对可交互元素生效
          var target = e.target.closest("a, button, .ink-btn, .card-ink, .ink-tag, .nav-link, .mobile-nav-link, .nav-icon-btn");
          if (!target) return;
          // 如果元素已有 ink-drop-effect 类，跳过（让 CSS 处理）
          if (target.classList.contains("ink-drop-effect")) return;
          // 避免重复快速点击
          if (target._inkRippleTimer) return;
          target._inkRippleTimer = true;
          setTimeout(function() { target._inkRippleTimer = false; }, 600);
          
          var rect = target.getBoundingClientRect();
          var ripple = document.createElement("span");
          ripple.className = "ink-ripple";
          var size = Math.max(rect.width, rect.height) * 0.8;
          ripple.style.width = size + "px";
          ripple.style.height = size + "px";
          ripple.style.left = (e.clientX - rect.left) + "px";
          ripple.style.top = (e.clientY - rect.top) + "px";
          ripple.style.position = "absolute";
          
          // 确保目标元素有 relative 定位
          if (getComputedStyle(target).position === "static") {
            target.style.position = "relative";
          }
          target.style.overflow = "hidden";
          
          target.appendChild(ripple);
          setTimeout(function() { ripple.remove(); }, 700);
        });
      }
      
      // 在页面加载和导航后初始化
      function runInkRipple() {
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", initInkRipple);
        } else {
          initInkRipple();
        }
      }
      runInkRipple();
      document.addEventListener("astro:page-load", runInkRipple);
    </script>
  </body>
</html>














