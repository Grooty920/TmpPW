---
import "../styles/global.css";
export interface Props {
  title?: string;
  description?: string;
}
const { title = "LoveAlwaysHere", description = "Personal Blog & Tools" } = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body class="min-h-screen bg-gray-950 text-gray-100">
    <nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-xl bg-gray-950/70 border-b border-gray-800/50">
      <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="/" class="text-xl font-bold bg-gradient-to-r from-cyan-400 to-violet-500 bg-clip-text text-transparent">LoveAlwaysHere</a>
        <div class="flex items-center gap-6 text-sm">
          <a href="/" class="text-gray-400 hover:text-cyan-400 transition-colors">首页</a>
          <a href="/blog" class="text-gray-400 hover:text-cyan-400 transition-colors">博客</a>
          <a href="/tools" class="text-gray-400 hover:text-cyan-400 transition-colors">工具</a>
        </div>
      </div>
    </nav>
    <main class="pt-16">
      <slot />
    </main>
    <footer class="border-t border-gray-800/50 py-8 mt-20">
      <div class="max-w-5xl mx-auto px-6 text-center text-sm text-gray-600">
        <p>© 2026 LoveAlwaysHere &middot; Built with Astro &amp; Tailwind CSS</p>
      </div>
    </footer>
  </body>
</html>