---
import Layout from "../../layouts/Layout.astro";
import AuthorCard from "../../components/AuthorCard.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const sorted = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const idx = sorted.findIndex((p) => p.slug === post.slug);
const prev = idx < sorted.length - 1 ? sorted[idx + 1] : null;
const next = idx > 0 ? sorted[idx - 1] : null;
---

<Layout title={post.data.title + " · 小杨王子"} description={post.data.description}>
  {post.data.coverImage && (
    <div class="relative h-64 md:h-96 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-black/40 to-transparent z-10"></div>
      <img src={post.data.coverImage} alt={post.data.title} class="w-full h-full object-cover parallax-img" />
    </div>
  )}

  <div class="container-page py-10">
    <div class="flex flex-col lg:flex-row gap-10">
      <article class="flex-1 min-w-0 max-w-3xl reveal">
        <header class="mb-10">
          <span class="inline-block px-2 py-1 text-xs mb-4 ink-tag" style="background-color:var(--accent);color:#fff;">{post.data.category}</span>
          <h1 class="text-3xl md:text-4xl font-serif font-bold leading-tight mb-4" style="color:var(--text-primary)">{post.data.title}</h1>
          <div class="flex flex-wrap items-center gap-4 text-sm" style="color:var(--text-secondary)">
            <span>{post.data.date.toLocaleDateString("zh-CN")}</span>
            <span>·</span>
            <span>{post.data.readingTime || 5} 分钟</span>
          </div>
        </header>

        <div class="prose-content">
          <Content />
        </div>

        {post.data.tags && post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-10 pt-8" style="border-top:1px solid var(--border)">
            {post.data.tags.map((tag) => (
              <span class="px-2 py-1 text-xs ink-tag">#{tag}</span>
            ))}
          </div>
        )}

        <div class="flex flex-col sm:flex-row gap-4 mt-10 pt-8 reveal" style="border-top:1px solid var(--border)">
          {prev && (
            <a href={"/blog/" + prev.slug} class="flex-1 p-4 card-ink transition-all duration-300 hover:scale-105" style="background-color:var(--card-bg);border:1px solid var(--border)">
              <span class="text-xs" style="color:var(--text-secondary)">← 上一篇</span>
              <p class="text-sm font-medium mt-1 line-clamp-1" style="color:var(--text-primary)">{prev.data.title}</p>
            </a>
          )}
          <div class="flex-1"></div>
          {next && (
            <a href={"/blog/" + next.slug} class="flex-1 p-4 card-ink text-right transition-all duration-300 hover:scale-105" style="background-color:var(--card-bg);border:1px solid var(--border)">
              <span class="text-xs" style="color:var(--text-secondary)">下一篇 →</span>
              <p class="text-sm font-medium mt-1 line-clamp-1" style="color:var(--text-primary)">{next.data.title}</p>
            </a>
          )}
        </div>

        <div class="mt-10">
          <AuthorCard />
        </div>

        <!-- 评论区 - Twikoo -->
        <div class="mt-10" id="comment-section">
          <div class="card-ink p-6 md:p-8 reveal" style="animation-delay:0.4s">
            <div class="flex items-center gap-3 mb-6">
              <span class="w-1 h-5" style="background-color:var(--accent)"></span>
              <h3 class="text-lg font-serif font-bold" style="color:var(--text-primary)">笔墨留痕</h3>
            </div>
            <div id="tcomment"></div>
          </div>
        </div>
      </article>

      <aside class="hidden lg:block w-64 shrink-0 reveal-right">
        <div class="sticky top-24">
          <h4 class="text-xs font-semibold uppercase tracking-widest mb-4" style="color:var(--text-secondary)">目录</h4>
          <nav id="toc" class="space-y-1"></nav>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<script>
// 动态导入 Twikoo，避免打包到主 chunk
function initTwikoo() {
  var el = document.getElementById("tcomment");
  if (!el || el.dataset.loaded) return;
  el.dataset.loaded = "1";
  import("twikoo").then(function(twikoo) {
    twikoo.init({
      envId: "https://twikoo-teal.vercel.app",
      el: "#tcomment",
      lang: "zh-CN",
    }).then(function() {
      console.log("Twikoo: 初始化成功");
    }).catch(function(err) {
      console.error("Twikoo: 初始化失败:", err);
    });
  }).catch(function(err) {
    console.error("Twikoo: 加载失败:", err);
  });
}

document.addEventListener("DOMContentLoaded", initTwikoo);
document.addEventListener("astro:page-load", initTwikoo);
</script>

<style is:global>
/* ===== Twikoo 评论区 - 水墨主题 ===== */
/* ===== Twikoo ===== */
#comment-section .card-ink { overflow: hidden; width: 100%; max-width: 100%; }
#tcomment { width: 100%; max-width: 100%; overflow: hidden; --twikoo-border-color: var(--border); --twikoo-bg-color: transparent; --twikoo-text-color: var(--text-primary); --twikoo-secondary-text-color: var(--text-secondary); --twikoo-accent-color: var(--accent); --twikoo-accent-hover-color: var(--accent-light); --twikoo-font-family: "Noto Serif SC", "LXGW WenKai", serif; --twikoo-font-size: 0.875rem; --twikoo-border-radius: 4px; --twikoo-input-bg-color: var(--card-bg); --twikoo-input-border-color: var(--border); --twikoo-input-focus-border-color: var(--accent); --twikoo-button-bg-color: var(--accent); --twikoo-button-text-color: #f7f3e8; --twikoo-button-hover-bg-color: var(--accent-light); --twikoo-tag-bg-color: rgba(199,62,58,0.08); --twikoo-tag-text-color: var(--accent); --twikoo-comment-bg-color: var(--card-bg); --twikoo-comment-border-color: var(--border); --twikoo-reply-bg-color: rgba(247,243,232,0.3); --twikoo-code-bg-color: rgba(28,28,28,0.04); --twikoo-code-text-color: var(--text-primary); --twikoo-success-color: var(--stone); --twikoo-error-color: var(--accent); --twikoo-loading-color: var(--accent); }
#tcomment .tk-comments, #tcomment .tk-submit { width: 100%; max-width: 100%; margin-top: 0; }
#tcomment .tk-submit { margin-bottom: 1.5rem; }
#tcomment .tk-row { display: flex; align-items: center; gap: 0.75rem; width: 100%; }
#tcomment .tk-input { width: 100%; box-sizing: border-box; border: 1px solid var(--twikoo-input-border-color); background: var(--twikoo-input-bg-color); border-radius: 4px; padding: 0.625rem 0.875rem; font-family: var(--twikoo-font-family); font-size: var(--twikoo-font-size); color: var(--twikoo-text-color); transition: border-color 0.3s ease; }
#tcomment .tk-input:focus { border-color: var(--twikoo-input-focus-border-color); outline: none; box-shadow: 0 0 0 2px rgba(199,62,58,0.1); }
#tcomment .tk-btn { font-family: var(--twikoo-font-family); font-size: 0.8125rem; padding: 0.5rem 1.25rem; border-radius: 4px; border: 1px solid var(--accent); background: var(--accent); color: #f7f3e8; cursor: pointer; transition: all 0.3s ease; letter-spacing: 0.05em; white-space: nowrap; }
#tcomment .tk-btn:hover { background: var(--accent-light); border-color: var(--accent-light); transform: translateY(-1px); box-shadow: 0 2px 12px rgba(199,62,58,0.2); }
#tcomment .tk-comment { width: 100%; max-width: 100%; box-sizing: border-box; border: 1px solid var(--twikoo-comment-border-color); background: var(--twikoo-comment-bg-color); border-radius: 4px; padding: 1rem; margin-bottom: 0.75rem; transition: all 0.3s ease; word-wrap: break-word; overflow-wrap: break-word; }
#tcomment .tk-comment:hover { border-color: var(--accent); box-shadow: 0 2px 8px rgba(0,0,0,0.04); }
#tcomment .tk-nick { font-family: "Ma Shan Zheng", "Noto Serif SC", cursive; font-size: 0.9375rem; color: var(--text-primary); }
#tcomment .tk-time { font-size: 0.75rem; color: var(--text-secondary); }
#tcomment .tk-content { font-size: 0.875rem; line-height: 1.7; color: var(--text-primary); word-wrap: break-word; overflow-wrap: break-word; }
#tcomment .tk-tag { background: rgba(199,62,58,0.08); color: var(--accent); border: none; font-size: 0.6875rem; padding: 0.125rem 0.5rem; border-radius: 2px; }
#tcomment .tk-actions a { color: var(--text-secondary); font-size: 0.75rem; transition: color 0.3s ease; }
#tcomment .tk-actions a:hover { color: var(--accent); }
#tcomment .tk-preview { border: 1px dashed var(--border); background: var(--card-bg); border-radius: 4px; padding: 1rem; }
#tcomment .tk-content img { max-width: 100%; height: auto; }
#tcomment .tk-emoji { max-width: 1.5rem; max-height: 1.5rem; vertical-align: middle; }
#tcomment .tk-owo { max-height: 200px; overflow-y: auto; border: 1px solid var(--border); background: var(--card-bg); border-radius: 4px; padding: 0.5rem; }
#tcomment .tk-owo .tk-owo-item { cursor: pointer; transition: transform 0.2s ease; }
#tcomment .tk-owo .tk-owo-item:hover { transform: scale(1.15); }
#tcomment .tk-loading { display: flex; align-items: center; justify-content: center; gap: 0.5rem; padding: 2rem; color: var(--text-secondary); font-size: 0.875rem; }
#tcomment .tk-no-comments { text-align: center; padding: 2rem; color: var(--text-secondary); font-size: 0.875rem; font-family: "LXGW WenKai", serif; }
.dark #tcomment { --twikoo-reply-bg-color: rgba(26,21,16,0.5); --twikoo-code-bg-color: rgba(247,243,232,0.04); --twikoo-input-bg-color: rgba(26,21,16,0.5); --twikoo-comment-bg-color: rgba(26,21,16,0.3); }
.dark #tcomment .tk-comment:hover { box-shadow: 0 2px 12px rgba(0,0,0,0.2); }
@media (max-width: 640px) { #tcomment .tk-row { flex-direction: column; align-items: stretch; } #comment-section .card-ink { padding: 1rem; } }
</style>
