---
import Layout from "../../layouts/Layout.astro";
import AuthorCard from "../../components/AuthorCard.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const sorted = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const idx = sorted.findIndex((p) => p.slug === post.slug);
const prev = idx < sorted.length - 1 ? sorted[idx + 1] : null;
const next = idx > 0 ? sorted[idx - 1] : null;
---
<Layout title={post.data.title + " · 小杨王子"} description={post.data.description}>
  {post.data.coverImage && (
    <div class="relative h-64 md:h-96 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-black/40 to-transparent z-10"></div>
      <img src={post.data.coverImage} alt={post.data.title} class="w-full h-full object-cover parallax-img" />
    </div>
  )}

  <div class="container-page py-10">
    <div class="flex flex-col lg:flex-row gap-10">
      <article class="flex-1 min-w-0 max-w-3xl reveal">
        <header class="mb-10">
          <span class="inline-block px-2 py-1 text-xs mb-4 ink-tag" style="background-color:var(--accent);color:#fff;">{post.data.category}</span>
          <h1 class="text-3xl md:text-4xl font-serif font-bold leading-tight mb-4" style="color:var(--text-primary)">{post.data.title}</h1>
          <div class="flex flex-wrap items-center gap-4 text-sm" style="color:var(--text-secondary)">
            <span>{post.data.date.toLocaleDateString("zh-CN")}</span>
            <span>·</span>
            <span>{post.data.readingTime || 5} 分钟</span>
          </div>
        </header>

        <div class="prose-content">
          <Content />
        </div>

        {post.data.tags && post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-10 pt-8" style="border-top:1px solid var(--border)">
            {post.data.tags.map((tag) => (
              <span class="px-2 py-1 text-xs ink-tag">#{tag}</span>
            ))}
          </div>
        )}

        <div class="text-center py-10">
          <button id="like-btn" class="inline-flex items-center gap-2 px-6 py-3 rounded-full text-sm transition-all duration-300 hover:scale-110" style="border:1px solid var(--border);color:var(--text-secondary)">
            <svg id="heart-icon" class="w-5 h-5 transition-all duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
            </svg>
            <span id="like-text">心有戚戚？点朱砂</span>
          </button>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 mt-10 pt-8 reveal" style="border-top:1px solid var(--border)">
          {prev && (
            <a href={"/blog/" + prev.slug} class="flex-1 p-4 card-ink transition-all duration-300 hover:scale-105" style="background-color:var(--card-bg);border:1px solid var(--border)">
              <span class="text-xs" style="color:var(--text-secondary)">← 上一篇</span>
              <p class="text-sm font-medium mt-1 line-clamp-1" style="color:var(--text-primary)">{prev.data.title}</p>
            </a>
          )}
          <div class="flex-1"></div>
          {next && (
            <a href={"/blog/" + next.slug} class="flex-1 p-4 card-ink text-right transition-all duration-300 hover:scale-105" style="background-color:var(--card-bg);border:1px solid var(--border)">
              <span class="text-xs" style="color:var(--text-secondary)">下一篇 →</span>
              <p class="text-sm font-medium mt-1 line-clamp-1" style="color:var(--text-primary)">{next.data.title}</p>
            </a>
          )}
        </div>

        <div class="mt-10">
          <AuthorCard />
        </div>

        <!-- 社交分享 -->
        <div class="mt-10 reveal" style="animation-delay:0.2s">
          <div class="flex items-center justify-center gap-4 p-6 card-ink">
            <span class="text-xs" style="color:var(--text-secondary)">分享此文</span>
            <button id="share-twitter" class="w-9 h-9 rounded-full flex items-center justify-center transition-all duration-300 hover:scale-110 hover:bg-blue-50" style="border:1px solid var(--border);color:var(--text-secondary)" aria-label="分享到 Twitter/X">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </button>
            <button id="share-weibo" class="w-9 h-9 rounded-full flex items-center justify-center transition-all duration-300 hover:scale-110 hover:bg-red-50" style="border:1px solid var(--border);color:var(--text-secondary)" aria-label="分享到微博">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M10.098 20.323c-3.977.391-7.414-1.406-7.672-4.02-.259-2.609 2.759-5.047 6.74-5.441 3.979-.394 7.413 1.404 7.671 4.018.259 2.6-2.759 5.049-6.739 5.443zM9.05 17.219c-.464.614-1.452.937-2.196.719-.744-.218-1.007-.945-.543-1.559.465-.614 1.43-.937 2.173-.725.744.213 1.031.944.566 1.565zm-1.492-1.623c-.187.232-.548.359-.805.284-.256-.074-.314-.319-.129-.548.186-.229.539-.35.798-.279.258.069.32.31.136.543zm-1.315.15c-.211.174-.5.23-.641.122-.141-.106-.09-.343.119-.518.211-.175.499-.233.641-.124.142.108.089.346-.119.52zm4.447-1.349c.08.14.013.31-.15.38-.163.07-.36.012-.44-.128-.08-.139-.014-.31.149-.38.163-.07.36-.013.441.128zm.707.304c.162.058.214.24.114.41-.099.168-.301.258-.464.195-.164-.064-.218-.243-.121-.418.099-.175.298-.256.471-.187zM3.596 13.38s.395-.365 1.173-.528c.777-.163 1.273.062 1.273.062s.244.576.033 1.08c-.21.505-.767.952-.767.952s-.82-.2-1.186-.826c-.366-.627-.526-.74-.526-.74zm5.217-1.596c-.01.124-.114.217-.236.21-.12-.007-.216-.112-.206-.237.01-.126.113-.22.235-.211.121.009.218.114.207.238zM20.137 6.82c-2.084-2.807-5.566-4.558-9.535-4.475C5.697 2.48 1.734 5.628.5 9.804c-.518 1.752-.5 3.35.161 4.587.137.257.303.49.498.692.788.845 1.892 1.4 3.125 1.693.225.055.45.1.68.134.223.03.423.09.577.192.595.374.68 1.067.62 1.614-.064.579-.316 1.114-.667 1.505-.328.363-.746.636-1.203.792-.524.18-1.1.238-1.662.206a5.46 5.46 0 0 1-1.14-.22c-.25-.08-.447-.137-.652-.137-.234 0-.42.09-.56.25-.143.165-.193.38-.14.59.08.32.28.62.56.86 1.08.93 2.636 1.5 4.366 1.5.33 0 .66-.02.99-.06 3.58-.4 6.5-1.85 8.56-4.01 2.07-2.17 3.36-5.02 3.77-8.27.08-.64.12-1.29.11-1.94 0-.32-.02-.64-.05-.96.19-.58.18-1.2-.17-1.84z"/></svg>
            </button>
            <button id="share-copy" class="w-9 h-9 rounded-full flex items-center justify-center transition-all duration-300 hover:scale-110 hover:bg-green-50" style="border:1px solid var(--border);color:var(--text-secondary)" aria-label="复制链接">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            </button>
          </div>
        </div>

        <!-- 评论区 - 本地留言 -->
        <div class="mt-10 reveal" style="animation-delay:0.3s">
          <div class="flex items-center gap-3 mb-6">
            <span class="w-1 h-5" style="background-color:var(--accent)"></span>
            <h2 class="text-lg font-serif font-semibold" style="color:var(--text-primary)">笔墨留痕</h2>
          </div>
          <div class="card-ink p-6">
            <div id="comments-area">
              <div id="comments-list" class="space-y-4 mb-6"></div>
              <div class="border-t pt-6" style="border-color:var(--border)">
                <textarea id="comment-input" rows="3" class="w-full p-3 text-sm outline-none transition-all duration-300" style="border:1px solid var(--border);border-radius:6px;background:var(--bg-primary);color:var(--text-primary);font-family:inherit;" placeholder="写下你的想法..."></textarea>
                <div class="flex items-center justify-between mt-3">
                  <input id="comment-author" type="text" placeholder="你的名字（选填）" class="text-sm p-2 outline-none" style="border:1px solid var(--border);border-radius:4px;background:var(--bg-primary);color:var(--text-primary);width:160px;font-family:inherit;">
                  <button id="comment-submit" class="ink-btn px-5 py-2 text-sm" style="border:1px solid var(--accent);color:var(--accent);">留墨</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </article>

      <aside class="hidden lg:block w-64 shrink-0 reveal-right">
        <div class="sticky top-24">
          <h4 class="text-xs font-semibold uppercase tracking-widest mb-4" style="color:var(--text-secondary)">目录</h4>
          <nav id="toc" class="space-y-1"></nav>
        </div>
      </aside>
    </div>
  </div>
  <script>
    function initArticle() {
      var parallax = document.querySelector(".parallax-img");
      if (parallax) {
        window.addEventListener("scroll", function() {
          parallax.style.transform = "translateY(" + window.scrollY * 0.3 + "px)";
        }, { passive: true });
      }

      var toc = document.getElementById("toc");
      if (toc) {
        toc.innerHTML = "";
        var headings = document.querySelectorAll(".prose-content h2, .prose-content h3");
        var items = [];
        headings.forEach(function(h, i) {
          if (!h.id) h.id = "heading-" + i;
          var a = document.createElement("a");
          a.href = "#" + h.id;
          a.textContent = h.textContent;
          a.className = "block text-sm py-1 transition-colors duration-300 rounded px-2";
          a.style.color = "var(--text-secondary)";
          if (h.tagName === "H3") { a.style.paddingLeft = "1.5rem"; a.style.fontSize = "0.8rem"; }
          a.addEventListener("click", function(e) {
            e.preventDefault();
            document.getElementById(h.id)?.scrollIntoView({ behavior: "smooth" });
          });
          toc.appendChild(a);
          items.push({ el: a, heading: h });
        });
        if (items.length > 0) {
          window.addEventListener("scroll", function() {
            var scrollY = window.scrollY + 100;
            var current = null;
            for (var i = 0; i < items.length; i++) {
              if (items[i].heading.offsetTop <= scrollY) current = items[i];
            }
            items.forEach(function(item) {
              item.el.style.color = "var(--text-secondary)";
              item.el.style.fontWeight = "normal";
            });
            if (current) {
              current.el.style.color = "var(--accent)";
              current.el.style.fontWeight = "600";
            }
          }, { passive: true });
        }
      }

      var likeBtn = document.getElementById("like-btn");
      var heartIcon = document.getElementById("heart-icon");
      var likeText = document.getElementById("like-text");
      if (likeBtn && heartIcon && likeText) {
        likeBtn.onclick = function() {
          var liked = heartIcon.getAttribute("fill") === "currentColor";
          heartIcon.setAttribute("fill", liked ? "none" : "currentColor");
          if (liked) {
            heartIcon.style.color = "";
            likeText.textContent = "心有戚戚？点朱砂";
          } else {
            heartIcon.style.color = "var(--accent)";
            likeText.textContent = "已留印记";
            likeBtn.style.borderColor = "var(--accent)";
          }
        };
      }

      document.querySelectorAll("pre").forEach(function(pre) {
        if (pre.querySelector(".copy-btn")) return;
        var btn = document.createElement("button");
        btn.textContent = "抄录";
        btn.className = "copy-btn absolute top-2 right-2 px-2 py-1 rounded text-xs transition-all duration-300";
        btn.style.backgroundColor = "rgba(212, 154, 26, 0.2)";
        btn.style.color = "var(--accent)";
        btn.style.border = "none";
        btn.style.cursor = "pointer";
        pre.style.position = "relative";
        pre.appendChild(btn);
        btn.addEventListener("click", function() {
          var code = pre.querySelector("code");
          if (code) {
            navigator.clipboard.writeText(code.textContent || "").then(function() {
              btn.textContent = "已抄录";
              setTimeout(function() { btn.textContent = "抄录"; }, 2000);
            });
          }
        });
      });
    }

    // 社交分享
    function initShare() {
      var url = encodeURIComponent(window.location.href);
      var title = encodeURIComponent(document.title.replace(" · 小杨王子", ""));
      var shareTwitter = document.getElementById("share-twitter");
      var shareWeibo = document.getElementById("share-weibo");
      var shareCopy = document.getElementById("share-copy");
      if (shareTwitter) shareTwitter.addEventListener("click", function() { window.open("https://twitter.com/intent/tweet?text=" + title + "&url=" + url, "_blank", "width=600,height=400"); });
      if (shareWeibo) shareWeibo.addEventListener("click", function() { window.open("https://service.weibo.com/share/share.php?title=" + title + "&url=" + url, "_blank", "width=600,height=400"); });
      if (shareCopy) shareCopy.addEventListener("click", function() {
        navigator.clipboard.writeText(window.location.href).then(function() {
          shareCopy.innerHTML = "<svg class=\"w-4 h-4\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--accent)\" stroke-width=\"2\"><polyline points=\"20 6 9 17 4 12\"/></svg>";
          setTimeout(function() { shareCopy.innerHTML = "<svg class=\"w-4 h-4\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"/><path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"/></svg>"; }, 2000);
        });
      });
    }

    // 本地留言系统
    function initComments() {
      var btn = document.getElementById("comment-submit");
      var input = document.getElementById("comment-input");
      var author = document.getElementById("comment-author");
      var list = document.getElementById("comments-list");
      if (!btn || !input || !list) return;

      var slug = window.location.pathname.replace("/blog/", "").replace(/\/$/, "");
      var storageKey = "comments_" + slug;

      function loadComments() {
        try {
          var data = JSON.parse(localStorage.getItem(storageKey) || "[]");
          if (data.length === 0) {
            list.innerHTML = "<p class=\"text-sm text-center\" style=\"color:var(--text-secondary)\">暂无留墨，做第一个留下墨迹的人吧</p>";
            return;
          }
          list.innerHTML = data.map(function(c) {
            var date = new Date(c.time).toLocaleString("zh-CN");
            return "<div class=\"p-4\" style=\"border-bottom:1px solid var(--border)\">" +
              "<div class=\"flex items-center gap-2 mb-1\">" +
              "<span class=\"text-xs font-semibold\" style=\"color:var(--accent)\">" + (c.author || "墨客") + "</span>" +
              "<span class=\"text-xs\" style=\"color:var(--text-secondary);opacity:0.5\">" + date + "</span>" +
              "</div>" +
              "<p class=\"text-sm\" style=\"color:var(--text-primary)\">" + c.text + "</p>" +
              "</div>";
          }).join("");
        } catch(e) { list.innerHTML = ""; }
      }

      btn.addEventListener("click", function() {
        var text = input.value.trim();
        if (!text) { alert("请写下你的想法"); return; }
        var authorName = author.value.trim() || "墨客";
        try {
          var data = JSON.parse(localStorage.getItem(storageKey) || "[]");
          data.unshift({ text: text, author: authorName, time: Date.now() });
          localStorage.setItem(storageKey, JSON.stringify(data));
          input.value = "";
          loadComments();
        } catch(e) { alert("保存失败，请重试"); }
      });

      loadComments();
    }

    function runPage() {
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
          initArticle();
          setTimeout(function() { initShare(); initComments(); }, 300);
        });
      } else {
        initArticle();
        setTimeout(function() { initShare(); initComments(); }, 300);
      }
    }
    runPage();
    document.addEventListener('astro:page-load', function() {
      initArticle();
      setTimeout(function() { initShare(); initComments(); }, 300);
    });
  </script>
</Layout>
