---
import Layout from "../../layouts/Layout.astro";
---
<Layout title="博客 · LoveAlwaysHere" description="技术博客文章列表">
  <div class="max-w-4xl mx-auto px-6 py-16">
    <div class="text-center mb-16">
      <h1 class="text-4xl md:text-5xl font-extrabold bg-gradient-to-r from-cyan-300 to-violet-400 bg-clip-text text-transparent">&#x1f4dd; 博客</h1>
      <p class="mt-4 text-gray-500">记录技术思考，分享学习心得</p>
    </div>
    <div class="text-center py-20">
      <div class="text-6xl mb-6">&#x1f6a7;</div>
      <h2 class="text-2xl font-semibold text-gray-300 mb-3">正在建设中...</h2>
      <p class="text-gray-500 max-w-md mx-auto">第一篇博客文章正在撰写中，很快就会和大家见面。</p>
    </div>
  </div>
</Layout>