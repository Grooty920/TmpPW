---
import Layout from "../../layouts/Layout.astro";
import BlogListCard from "../../components/BlogListCard.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  const tagSet = new Set<string>();
  for (const post of posts) {
    if (post.data.tags) {
      for (const tag of post.data.tags) {
        tagSet.add(tag);
      }
    }
  }
  return [...tagSet].map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const allPosts = await getCollection("posts", ({ data }) => !data.draft);

// 收集标签统计
const tagMap = new Map();
for (const post of allPosts) {
  if (post.data.tags) {
    for (const t of post.data.tags) {
      tagMap.set(t, (tagMap.get(t) || 0) + 1);
    }
  }
}
const tags = [...tagMap.entries()].sort((a, b) => b[1] - a[1]);
const posts = allPosts
  .filter((post) => post.data.tags && post.data.tags.includes(tag))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title={"#" + tag + " · 小杨王子"} description={"标签 " + tag + " 下的文章"}>
  <div class="container-page py-20">
    <div class="text-center mb-12 reveal">
      <div class="inline-flex items-center gap-2 mb-4">
        <a href="/tags" class="text-xs transition-all duration-300 hover:text-gradient" style="color:var(--text-secondary)">标签</a>
        <span class="text-xs" style="color:var(--text-secondary)">/</span>
      </div>
      <h1 class="text-3xl md:text-4xl font-serif font-bold" style="color:var(--text-primary)">#{tag}</h1>
      <div class="mt-4 mx-auto w-12 h-0.5" style="background-color:var(--accent)"></div>
      <p class="text-xs mt-4" style="color:var(--text-secondary); font-family: 'LXGW WenKai', serif; letter-spacing: 0.2em;">共 {posts.length} 篇文章</p>
    </div>

    <!-- 相关标签 -->
    <div class="max-w-3xl mx-auto mb-10 reveal">
      <div class="flex flex-wrap items-center gap-2">
        <span class="text-xs mr-1" style="color:var(--text-secondary);letter-spacing:0.1em;">相关标签：</span>
        {tags.slice(0, 8).map(([t, cnt]) => (
          <a href={"/tags/" + t}
            class="inline-block px-3 py-1 text-xs rounded-full transition-all duration-300 hover:scale-105"
            style={t === tag ? "border:1px solid var(--accent);color:var(--accent);background:var(--accent-glow);" : "border:1px solid var(--border);color:var(--text-secondary);"}
          >{t} ({cnt})</a>
        ))}
      </div>
    </div>

    {posts.length === 0 && (
      <div class="text-center py-20 reveal">
        <p class="text-lg" style="color:var(--text-secondary)">此标签下暂无文章...</p>
      </div>
    )}

    <div class="max-w-3xl mx-auto space-y-6">
      {posts.map((post, index) => (
        <div class="reveal" style={"animation-delay:" + (0.1 + index * 0.08) + "s"}>
          <BlogListCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            slug={post.slug}
            category={post.data.category}
            coverImage={post.data.coverImage}
            readingTime={post.data.readingTime}
            tags={post.data.tags}
          />
        </div>
      ))}
    </div>

    <div class="mt-12 text-center reveal">
      <a href="/tags" class="ink-btn px-5 py-2.5 text-sm" style="border:1px solid var(--accent);color:var(--accent);">
        所有标签  →
      </a>
    </div>
  </div>
</Layout>