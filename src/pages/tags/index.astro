---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("posts", ({ data }) => !data.draft);

// 收集所有标签并统计文章数
const tagMap = new Map<string, number>();
for (const post of posts) {
  if (post.data.tags) {
    for (const tag of post.data.tags) {
      tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
    }
  }
}
// 按文章数排序
const tags = [...tagMap.entries()].sort((a, b) => b[1] - a[1]);
const totalTags = tags.length;
---

<Layout title="标签 · 小杨王子" description="笔墨标签，按图索骥">
  <div class="container-page py-20">
    <div class="text-center mb-16 reveal">
      <h1 class="text-3xl md:text-4xl font-serif font-bold" style="color:var(--text-primary)">笔墨标签</h1>
      <div class="mt-4 mx-auto w-12 h-0.5" style="background-color:var(--accent)"></div>
      <p class="text-xs mt-4" style="color:var(--text-secondary); font-family: 'LXGW WenKai', serif; letter-spacing: 0.2em;">按图索骥，寻笔墨踪迹</p>
    </div>

    {totalTags === 0 && (
      <div class="text-center py-20 reveal">
        <p class="text-lg" style="color:var(--text-secondary)">暂无标签...</p>
      </div>
    )}

    <div class="max-w-3xl mx-auto">
      <div class="flex flex-wrap justify-center gap-3">
        {tags.map(([tag, count], index) => {
          // 根据文章数计算标签大小，最大标签为基准
          const maxCount = tags.length > 0 ? tags[0][1] : 1;
          const ratio = count / maxCount;
          const fontSize = 0.8 + ratio * 0.5; // 0.8rem ~ 1.3rem
          const opacity = 0.6 + ratio * 0.4; // 0.6 ~ 1.0
          const padding = 0.5 + ratio * 0.5; // 0.5rem ~ 1.0rem
          return (
          <a
            href={"/tags/" + tag}
            class="group transition-all duration-300 hover:scale-110 reveal"
            style={"animation-delay:" + (0.03 + index * 0.02) + "s;padding:" + padding + "rem 1rem;border-radius:8px;background:rgba(199,62,58," + (0.04 + ratio * 0.08) + ");border:1px solid rgba(199,62,58," + (0.1 + ratio * 0.2) + ");"}
          >
            <span class="font-serif font-semibold transition-colors duration-300 group-hover:text-gradient" style="font-size:" + fontSize + "rem;color:var(--text-primary);">#{tag}</span>
            <span class="ml-1.5" style="font-size:" + (fontSize * 0.75) + "rem;color:var(--accent);opacity:" + opacity + ";">{count}</span>
          </a>
          );
        })}
      </div>
    </div>

    <!-- 寄语 -->
    <div class="mt-20 text-center reveal">
      <div class="max-w-lg mx-auto">
        <div class="w-12 h-[1px] mx-auto mb-6" style="background:var(--border);"></div>
        <p class="text-sm" style="color:var(--text-secondary); font-family: 'LXGW WenKai', serif;">字里行间，皆有回响</p>
      </div>
    </div>
  </div>
</Layout>
