---
import Layout from "../layouts/Layout.astro";
---

<Layout title="关于 · 小杨王子" description="寄蜉蝣于天地，渺沧海之一粟 — 关于小杨王子">
  <div class="container-page py-20">
    <!-- 头部 -->
    <div class="text-center mb-16 reveal">
      <h1 class="text-3xl md:text-4xl font-serif font-bold" style="color:var(--text-primary)">关于</h1>
      <div class="mt-4 mx-auto w-12 h-0.5" style="background-color:var(--accent)"></div>
      <p class="text-xs mt-4" style="color:var(--text-secondary); font-family: &apos;LXGW WenKai&apos;, serif; letter-spacing: 0.2em;">山水有相逢，笔墨寄知音</p>
    </div>

    <div class="max-w-3xl mx-auto space-y-10">
      <!-- 个人简介 -->
      <div class="flex flex-col md:flex-row items-center gap-10 p-8 card-ink reveal" style="border-left: 3px solid var(--accent);">
        <div class="shrink-0">
          <div class="w-28 h-28 rounded-full border-4 overflow-hidden transition-all duration-500 hover:rotate-12 hover:scale-105" style="border-color:var(--accent)">
            <img src="/avatar.jpg" alt="头像" class="w-full h-full object-cover" />
          </div>
        </div>
        <div class="text-center md:text-left">
          <h2 class="text-2xl font-serif font-bold mb-2" style="color:var(--text-primary)">小杨王子</h2>
          <p class="text-sm leading-relaxed" style="color:var(--text-secondary); font-family: &apos;LXGW WenKai&apos;, serif;">
            寄蜉蝣于天地，渺沧海之一粟。<br/>
            好读书，不求甚解；每有会意，便欣然忘食。<br/>
            此间所录，皆沿途之风景与思考。愿与君共赏。
          </p>
        </div>
      </div>

      <!-- 关于这个博客 -->
      <div class="p-8 card-ink reveal" style="border-left: 3px solid var(--stone);">
        <h2 class="text-xl font-serif font-semibold mb-4" style="color:var(--text-primary)">关于这个博客</h2>
        <div class="space-y-3 text-sm leading-relaxed" style="color:var(--text-secondary)">
          <p><strong style="color:var(--text-primary)">小杨王子</strong> —— 墨水的墨，言语的言。</p>
          <p>以笔墨为舟，渡无涯之学海。好读书，不求甚解；每有会意，便欣然忘食。</p>
          <p>博客使用 <strong style="color:var(--accent)">Astro</strong> + <strong style="color:var(--accent)">Tailwind CSS</strong> 构建，部署在 Cloudflare Pages 上。</p>
          <p>主题灵感来源于中国传统水墨画，融入现代 Web 技术，营造一种"纸上得来终觉浅，绝知此事要躬行"的意境。</p>
        </div>
      </div>

      <!-- 笔墨纸砚 -->
      <div class="p-8 card-ink reveal" style="border-left: 3px solid var(--accent);">
        <h2 class="text-xl font-serif font-semibold mb-5" style="color:var(--text-primary)">笔墨纸砚</h2>
        <div class="flex flex-wrap gap-3">
          <span class="px-4 py-1.5 text-sm ink-tag">Astro 5</span>
          <span class="px-4 py-1.5 text-sm ink-tag">Tailwind CSS 3</span>
          <span class="px-4 py-1.5 text-sm ink-tag">MDX</span>
          <span class="px-4 py-1.5 text-sm ink-tag">TypeScript</span>
          <span class="px-4 py-1.5 text-sm ink-tag">Cloudflare Pages</span>
          <span class="px-4 py-1.5 text-sm ink-tag">霞鹜文楷</span>
          <span class="px-4 py-1.5 text-sm ink-tag">马山正体</span>
        </div>
      </div>

      <!-- 寄语 -->
      <div class="p-10 card-ink text-center reveal">
        <h2 class="text-xl font-serif font-semibold mb-3" style="color:var(--text-primary)">寄语</h2>
        <p class="text-sm mb-6" style="color:var(--text-secondary); font-family: &apos;LXGW WenKai&apos;, serif;">山水有相逢，来日皆可期</p>
        <div class="flex justify-center gap-4">
          <a href="mailto:Grooty920@gmail.com" class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium transition-all duration-300 hover:scale-105" style="background-color:var(--accent);color:#fff">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            邮件联系
          </a>
          <a href="https://github.com/Grooty920" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium transition-all duration-300 hover:scale-105" style="border:1px solid var(--accent);color:var(--accent)">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>


