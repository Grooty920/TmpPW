---
import Layout from "../layouts/Layout.astro";
---
<Layout title="LoveAlwaysHere 首页" description="个人博客与工具集">
  <div class="relative">
    <!-- Hero 区 -->
    <section class="relative max-w-5xl mx-auto px-6 pt-28 pb-20 text-center">
      <div class="inline-block px-5 py-2 rounded-full border border-cyan-500/20 bg-cyan-500/5 text-cyan-400 text-xs tracking-widest mb-8 backdrop-blur-sm animate-fade-in">
        &#x2728; 个人空间 &middot; 技术博客 &middot; 实用工具
      </div>

      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight leading-tight animate-fade-in" style="animation-delay:0.1s">
        <span class="bg-gradient-to-r from-cyan-300 via-cyan-400 to-violet-500 bg-clip-text text-transparent">
          探索 &middot; 创造 &middot; 分享
        </span>
      </h1>

      <p class="mt-6 text-lg md:text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed animate-fade-in" style="animation-delay:0.2s">
        记录技术思考，分享实用工具<br class="hidden md:block" />
        在代码与创造之间，寻找属于自己的节奏
      </p>

      <div class="mt-10 flex flex-wrap gap-5 justify-center animate-fade-in" style="animation-delay:0.3s">
        <a href="/blog" class="group relative px-8 py-3.5 rounded-xl bg-gradient-to-r from-cyan-500 to-cyan-600 text-white font-medium overflow-hidden transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-cyan-500/30">
          <span class="relative z-10">浏览博客 &#8594;</span>
          <div class="absolute inset-0 bg-gradient-to-r from-cyan-400 to-cyan-500 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        </a>
        <a href="/tools" class="group relative px-8 py-3.5 rounded-xl border border-gray-600 text-gray-300 font-medium overflow-hidden transition-all duration-300 hover:border-cyan-400/50 hover:text-cyan-300 hover:scale-105">
          <span class="relative z-10">实用工具</span>
          <div class="absolute inset-0 bg-cyan-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        </a>
      </div>
    </section>

    <!-- 特色卡片 -->
    <section class="max-w-5xl mx-auto px-6 pb-20 grid md:grid-cols-3 gap-6">
      <div class="group p-7 rounded-2xl border border-gray-800/50 bg-gray-900/30 backdrop-blur-sm hover:border-cyan-500/30 hover:bg-gray-900/50 hover:shadow-lg hover:shadow-cyan-500/5 transition-all duration-500 hover:-translate-y-1">
        <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-cyan-500/20 to-cyan-600/5 flex items-center justify-center text-2xl mb-5 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500">&#x1f4dd;</div>
        <h3 class="text-lg font-semibold text-gray-100 mb-3 group-hover:text-cyan-300 transition-colors duration-300">技术博客</h3>
        <p class="text-sm text-gray-500 leading-relaxed group-hover:text-gray-400 transition-colors duration-300">记录前端、全栈开发中的踩坑与思考，分享技术心得与最佳实践。</p>
      </div>
      <div class="group p-7 rounded-2xl border border-gray-800/50 bg-gray-900/30 backdrop-blur-sm hover:border-violet-500/30 hover:bg-gray-900/50 hover:shadow-lg hover:shadow-violet-500/5 transition-all duration-500 hover:-translate-y-1">
        <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-violet-500/20 to-violet-600/5 flex items-center justify-center text-2xl mb-5 group-hover:scale-110 group-hover:-rotate-3 transition-all duration-500">&#x1f527;</div>
        <h3 class="text-lg font-semibold text-gray-100 mb-3 group-hover:text-violet-300 transition-colors duration-300">实用工具</h3>
        <p class="text-sm text-gray-500 leading-relaxed group-hover:text-gray-400 transition-colors duration-300">日常开发和生活所需的在线小工具，开箱即用，持续更新。</p>
      </div>
      <div class="group p-7 rounded-2xl border border-gray-800/50 bg-gray-900/30 backdrop-blur-sm hover:border-amber-500/30 hover:bg-gray-900/50 hover:shadow-lg hover:shadow-amber-500/5 transition-all duration-500 hover:-translate-y-1">
        <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-amber-500/20 to-amber-600/5 flex items-center justify-center text-2xl mb-5 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500">&#x1f680;</div>
        <h3 class="text-lg font-semibold text-gray-100 mb-3 group-hover:text-amber-300 transition-colors duration-300">持续进化</h3>
        <p class="text-sm text-gray-500 leading-relaxed group-hover:text-gray-400 transition-colors duration-300">不断迭代优化，让这个数字花园越来越丰富。</p>
      </div>
    </section>

    <!-- 最新动态 -->
    <section class="max-w-5xl mx-auto px-6 pb-20">
      <div class="flex items-center gap-3 mb-10">
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-gray-700 to-transparent"></div>
        <span class="text-sm text-gray-500 tracking-widest">最新动态</span>
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-gray-700 to-transparent"></div>
      </div>
      <div class="text-center py-12">
        <div class="text-5xl mb-5 animate-bounce">&#x2728;</div>
        <p class="text-gray-500 text-lg">博客文章正在路上，敬请期待...</p>
        <div class="mt-6 flex justify-center gap-2">
          <div class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse" style="animation-delay:0s"></div>
          <div class="w-2 h-2 rounded-full bg-violet-400 animate-pulse" style="animation-delay:0.2s"></div>
          <div class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse" style="animation-delay:0.4s"></div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
    opacity: 0;
  }
</style>