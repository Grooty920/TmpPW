---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="工具 · 小杨王子" description="工欲善其事，必先利其器">
  <div class="container-page py-20">
    <div class="text-center mb-16 reveal">
      <h1 class="text-3xl md:text-4xl font-serif font-bold" style="color:var(--text-primary)">工具</h1>
      <div class="mt-4 mx-auto w-12 h-0.5" style="background-color:var(--accent)"></div>
      <p class="mt-4 text-sm" style="color:var(--text-secondary); font-family: 'LXGW WenKai', serif;">工欲善其事，必先利其器</p>
    </div>

    <!-- ===== 匠心 ===== -->
    <div class="mb-14 reveal">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-1 h-5" style="background-color:var(--accent);"></span>
        <h2 class="text-lg font-serif font-semibold" style="color:var(--text-primary)">匠心</h2>
        <span class="text-xs" style="color:var(--text-secondary); opacity:0.6;">—— 自家笔墨 ——</span>
      </div>
      <div class="max-w-xl">
        <a href="/tools/password" data-astro-reload class="card-ink p-5 flex items-center gap-4 group transition-all duration-300 hover:scale-[1.01]">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0 transition-all duration-300 group-hover:rotate-12" style="background-color:var(--accent);">
            <svg class="w-6 h-6" style="color:#fff" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="text-base font-serif font-semibold group-hover:text-gradient" style="color:var(--text-primary)">门锁密码分配系统</h3>
            <p class="text-sm mt-1" style="color:var(--text-secondary)">施工队智能门锁密码分配工具</p>
            
          </div>
          <svg class="w-5 h-5 shrink-0 transition-all duration-300 group-hover:translate-x-1" style="color:var(--text-secondary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
    <!-- ===== 器用 ===== -->
    <div class="mb-14 reveal">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-1 h-5" style="background-color:var(--accent);"></span>
        <h2 class="text-lg font-serif font-semibold" style="color:var(--text-primary)">器用</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 auto-rows-fr">
        <a href="https://mac.macxz.com/?id=MjAzMDkzNQ%3D%3D" target="_blank" rel="noopener" class="card-ink p-4 flex items-center gap-3 group transition-all duration-300 hover:scale-[1.02] h-full">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background-color:var(--accent-light);">
            <svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-medium truncate group-hover:text-gradient" style="color:var(--text-primary)">MAC软件</h3>
            <p class="text-xs truncate" style="color:var(--text-secondary)">mac.macxz.com</p>
          </div>
        </a>
        <a href="https://massgrave.dev/windows_11_links" target="_blank" rel="noopener" class="card-ink p-4 flex items-center gap-3 group transition-all duration-300 hover:scale-[1.02] h-full">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background-color:var(--accent-light);">
            <svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-medium truncate group-hover:text-gradient" style="color:var(--text-primary)">ISO镜像</h3>
            <p class="text-xs truncate" style="color:var(--text-secondary)">massgrave.dev</p>
          </div>
        </a>
        <a href="https://www.chrome64.com/" target="_blank" rel="noopener" class="card-ink p-4 flex items-center gap-3 group transition-all duration-300 hover:scale-[1.02] h-full">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background-color:var(--accent-light);">
            <svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="21.17" y1="8" x2="12" y2="8"/><line x1="3.95" y1="6.06" x2="8.54" y2="14"/><line x1="10.88" y1="21.94" x2="15.46" y2="14"/></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-medium truncate group-hover:text-gradient" style="color:var(--text-primary)">Chrome</h3>
            <p class="text-xs truncate" style="color:var(--text-secondary)">安卓/MAC/PC</p>
          </div>
        </a>
        <a href="https://www.nirsoft.net/utils/network_password_recovery.html" target="_blank" rel="noopener" class="card-ink p-4 flex items-center gap-3 group transition-all duration-300 hover:scale-[1.02] h-full">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background-color:var(--accent-light);">
            <svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-medium truncate group-hover:text-gradient" style="color:var(--text-primary)">凭据密码查看</h3>
            <p class="text-xs truncate" style="color:var(--text-secondary)">nirsoft.net</p>
          </div>
        </a>
      </div>
    </div>

    <!-- ===== 插件/驱动 ===== -->
    <div class="mb-14 reveal">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-1 h-5" style="background-color:var(--stone);"></span>
        <h2 class="text-lg font-serif font-semibold" style="color:var(--text-primary)">羽翼</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 auto-rows-fr">
        <a href="https://download.pytorch.org/whl" target="_blank" rel="noopener" class="card-ink p-4 flex items-center gap-3 group transition-all duration-300 hover:scale-[1.02] h-full">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background-color:var(--stone);">
            <svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-medium truncate group-hover:text-gradient" style="color:var(--text-primary)">Torch库</h3>
            <p class="text-xs truncate" style="color:var(--text-secondary)">download.pytorch.org</p>
          </div>
        </a>
        <a href="https://www.wch.cn/downloads/CH341SER_EXE.html" target="_blank" rel="noopener" class="card-ink p-4 flex items-center gap-3 group transition-all duration-300 hover:scale-[1.02] h-full">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background-color:var(--stone);">
            <svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-medium truncate group-hover:text-gradient" style="color:var(--text-primary)">USB串口驱动</h3>
            <p class="text-xs truncate" style="color:var(--text-secondary)">wch.cn</p>
          </div>
        </a>
        <a href="https://www.dll-files.com/" target="_blank" rel="noopener" class="card-ink p-4 flex items-center gap-3 group transition-all duration-300 hover:scale-[1.02] h-full">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background-color:var(--stone);">
            <svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-medium truncate group-hover:text-gradient" style="color:var(--text-primary)">DLL库</h3>
            <p class="text-xs truncate" style="color:var(--text-secondary)">dll-files.com</p>
          </div>
        </a>
        <a href="https://www.ijinshan.com/filerepair/dll/" target="_blank" rel="noopener" class="card-ink p-4 flex items-center gap-3 group transition-all duration-300 hover:scale-[1.02] h-full">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background-color:var(--stone);">
            <svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="M12 18v-6"/><path d="M9 15l3-3 3 3"/></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-medium truncate group-hover:text-gradient" style="color:var(--text-primary)">DLL修复</h3>
            <p class="text-xs truncate" style="color:var(--text-secondary)">ijinshan.com</p>
          </div>
        </a>
      </div>
    </div>

    <!-- ===== 百宝 ===== -->
    <div class="mb-14 reveal">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-1 h-5" style="background-color:var(--accent);"></span>
        <h2 class="text-lg font-serif font-semibold" style="color:var(--text-primary)">百宝</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 auto-rows-fr">
        <a href="https://tool.ear0.com/convert" target="_blank" rel="noopener" class="card-ink p-4 flex items-center gap-3 group transition-all duration-300 hover:scale-[1.02] h-full">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background-color:var(--accent-light);">
            <svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18V5l12-2v13"/><polyline points="9 9 21 7"/></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-medium truncate group-hover:text-gradient" style="color:var(--text-primary)">音频转换</h3>
            <p class="text-xs truncate" style="color:var(--text-secondary)">耳聆 · tool.ear0.com</p>
          </div>
        </a>
        <a href="https://123apps.com/" target="_blank" rel="noopener" class="card-ink p-4 flex items-center gap-3 group transition-all duration-300 hover:scale-[1.02] h-full">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background-color:var(--accent-light);">
            <svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18V5l12-2v13"/><polyline points="9 9 21 7"/></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-medium truncate group-hover:text-gradient" style="color:var(--text-primary)">音频处理</h3>
            <p class="text-xs truncate" style="color:var(--text-secondary)">123apps.com</p>
          </div>
        </a>
        <a href="https://web.baimiaoapp.com/" target="_blank" rel="noopener" class="card-ink p-4 flex items-center gap-3 group transition-all duration-300 hover:scale-[1.02] h-full">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background-color:var(--accent-light);">
            <svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-medium truncate group-hover:text-gradient" style="color:var(--text-primary)">OCR文字识别</h3>
            <p class="text-xs truncate" style="color:var(--text-secondary)">白描 · baimiaoapp.com</p>
          </div>
        </a>
        <a href="https://audio-joiner.com/cn/" target="_blank" rel="noopener" class="card-ink p-4 flex items-center gap-3 group transition-all duration-300 hover:scale-[1.02] h-full">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background-color:var(--accent-light);">
            <svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18V5l12-2v13"/><polyline points="9 9 21 7"/></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-medium truncate group-hover:text-gradient" style="color:var(--text-primary)">音频合成</h3>
            <p class="text-xs truncate" style="color:var(--text-secondary)">audio-joiner.com</p>
          </div>
        </a>
        <a href="https://www.tttci.com/" target="_blank" rel="noopener" class="card-ink p-4 flex items-center gap-3 group transition-all duration-300 hover:scale-[1.02] h-full">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background-color:var(--accent-light);">
            <svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-medium truncate group-hover:text-gradient" style="color:var(--text-primary)">提词器</h3>
            <p class="text-xs truncate" style="color:var(--text-secondary)">tttci.com</p>
          </div>
        </a>
        <a href="https://www.nirsoft.net/" target="_blank" rel="noopener" class="card-ink p-4 flex items-center gap-3 group transition-all duration-300 hover:scale-[1.02] h-full">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background-color:var(--accent-light);">
            <svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-medium truncate group-hover:text-gradient" style="color:var(--text-primary)">Password Tools</h3>
            <p class="text-xs truncate" style="color:var(--text-secondary)">nirsoft.net</p>
          </div>
        </a>
        <a href="https://safeexambrowser.org/download_en.html" target="_blank" rel="noopener" class="card-ink p-4 flex items-center gap-3 group transition-all duration-300 hover:scale-[1.02] h-full">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background-color:var(--accent-light);">
            <svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-medium truncate group-hover:text-gradient" style="color:var(--text-primary)">监考系统</h3>
            <p class="text-xs truncate" style="color:var(--text-secondary)">safeexambrowser.org</p>
          </div>
        </a>
      </div>
    </div>

    <!-- 寄语 -->
    <div class="mt-20 text-center reveal">
      <div class="max-w-lg mx-auto">
        <div class="w-12 h-[1px] mx-auto mb-6" style="background:var(--border);"></div>
        <p class="text-sm" style="color:var(--text-secondary); font-family: 'LXGW WenKai', serif;">君子生非异也，善假于物也</p>
      </div>
    </div>
  </div>
</Layout>








