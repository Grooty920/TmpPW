---
import Layout from "../../layouts/Layout.astro";
import toolsData from "../../data/tools.json";

// 图标映射
const iconMap = {
  lock: `<svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
  package: `<svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>`,
  grid: `<svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>`,
  chrome: `<svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="21.17" y1="8" x2="12" y2="8"/><line x1="3.95" y1="6.06" x2="8.54" y2="14"/><line x1="10.88" y1="21.94" x2="15.46" y2="14"/></svg>`,
  zap: `<svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
  file: `<svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
  "file-plus": `<svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="M12 18v-6"/><path d="M9 15l3-3 3 3"/></svg>`,
  music: `<svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18V5l12-2v13"/><polyline points="9 9 21 7"/></svg>`,
  book: `<svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
  message: `<svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  monitor: `<svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
  link: `<svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`,
  tool: `<svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  star: `<svg class="w-5 h-5" style="color:var(--bg-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
};
const defaultIcon = iconMap.link;
---

<Layout title="工具 · 小杨王子" description="工欲善其事，必先利其器">
  <div class="container-page py-20">
    <div class="text-center mb-16 reveal">
      <h1 class="text-3xl md:text-4xl font-serif font-bold" style="color:var(--text-primary)">工具</h1>
      <div class="mt-4 mx-auto w-12 h-0.5" style="background-color:var(--accent)"></div>
      <p class="mt-4 text-sm" style="color:var(--text-secondary); font-family: 'LXGW WenKai', serif;">工欲善其事，必先利其器</p>
    </div>

    {toolsData.categories.map((cat, catIndex) => (
      <div class="mb-14 reveal" style={catIndex === 0 ? "" : ""}>
        <div class="flex items-center gap-3 mb-6">
          <span class="w-1 h-5" style={"background-color:" + (cat.accentColor || "var(--accent)")}></span>
          <h2 class="text-lg font-serif font-semibold" style="color:var(--text-primary)">{cat.name}</h2>
          {cat.subtitle && (
            <span class="text-xs" style="color:var(--text-secondary); opacity:0.6;">{cat.subtitle}</span>
          )}
        </div>

        {cat.id === "masterpiece" ? (
          <!-- 匠心：独立宽卡片 -->
          <div class="max-w-xl">
            {cat.items.map((item) => (
              <a href={item.url} {...(item.isLocal ? {"data-astro-reload": true} : {target: "_blank", rel: "noopener"})} class="card-ink p-5 flex items-center gap-4 group transition-all duration-300 hover:scale-[1.01]">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0 transition-all duration-300 group-hover:rotate-12" style={"background-color:" + (cat.accentColor || "var(--accent)")}>
                  {iconMap[item.icon] || defaultIcon}
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="text-base font-serif font-semibold group-hover:text-gradient" style="color:var(--text-primary)">{item.title}</h3>
                  <p class="text-sm mt-1" style="color:var(--text-secondary)">{item.description}</p>
                </div>
                <svg class="w-5 h-5 shrink-0 transition-all duration-300 group-hover:translate-x-1" style="color:var(--text-secondary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            ))}
          </div>
        ) : (
          <!-- 其他分类：网格卡片 -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 auto-rows-fr">
            {cat.items.map((item) => (
              <a href={item.url} target="_blank" rel="noopener" class="card-ink p-4 flex items-center gap-3 group transition-all duration-300 hover:scale-[1.02] h-full">
                <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style={"background-color:" + (cat.accentColor || "var(--accent-light)")}>
                  {iconMap[item.icon] || defaultIcon}
                </div>
                <div class="min-w-0">
                  <h3 class="text-sm font-medium truncate group-hover:text-gradient" style="color:var(--text-primary)">{item.title}</h3>
                  <p class="text-xs truncate" style="color:var(--text-secondary)">{item.description}</p>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    ))}

    <!-- 寄语 -->
    <div class="mt-20 text-center reveal">
      <div class="max-w-lg mx-auto">
        <div class="w-12 h-[1px] mx-auto mb-6" style="background:var(--border);"></div>
        <p class="text-sm" style="color:var(--text-secondary); font-family: 'LXGW WenKai', serif;">君子生非异也，善假于物也</p>
      </div>
    </div>
  </div>
</Layout>
