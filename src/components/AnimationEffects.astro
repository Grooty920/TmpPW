---
// 水墨意境 - 动画与微交互系统（增强版）
// 墨韵流动 | 笔触书写 | 樱花飘落 | 星空闪烁 | 云雾飘动
---

<style is:global>


  /* ===== 暗色模式星空 ===== */
  .stars-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
    opacity: 0;
    transition: opacity 1s ease;
  }
  .dark .stars-container {
    opacity: 1;
  }
  .stars-container .star {
    position: absolute;
    width: 2px;
    height: 2px;
    background: #fff;
    border-radius: 50%;
    animation: starTwinkle ease-in-out infinite alternate;
  }
  .stars-container .star:nth-child(odd) {
    width: 1.5px;
    height: 1.5px;
  }
  .stars-container .star:nth-child(3n) {
    width: 2.5px;
    height: 2.5px;
  }
  @keyframes starTwinkle {
    0% { opacity: 0.1; transform: scale(0.8); }
    100% { opacity: 0.8; transform: scale(1.2); }
  }

  /* ===== 笔触书写动画 ===== */
  .brush-stroke-anim {
    position: relative;
    display: inline-block;
  }
  .brush-stroke-anim::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent 0%, var(--bg-primary) 50%, transparent 100%);
    animation: brushReveal 1.5s ease-out forwards;
  }
  @keyframes brushReveal {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }

  /* ===== 墨滴扩散 ===== */
  .ink-dot {
    position: absolute;
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 50%;
    pointer-events: none;
    animation: inkSpread 1.2s ease-out forwards;
  }
  @keyframes inkSpread {
    0% { transform: scale(0); opacity: 0.8; }
    50% { opacity: 0.4; }
    100% { transform: scale(8); opacity: 0; }
  }

  /* ===== 卷轴展开 ===== */
  .scroll-unfold {
    animation: scrollUnfold 1.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    overflow: hidden;
  }
  @keyframes scrollUnfold {
    0% { clip-path: inset(0 100% 0 0); }
    100% { clip-path: inset(0 0% 0 0); }
  }

  /* ===== 雪花飘落 ===== */
  #snow-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 1;
    pointer-events: none;
  }
</style>


<div class="stars-container" id="stars-container"></div>
<div id="mouse-glow"></div>
<canvas id="ink-canvas"></canvas>

<canvas id="snow-canvas"></canvas>
<script>
(function() {
  'use strict';

  // ===== 樱花飘落 =====
  function initBambooLeaves() {
    var container = document.getElementById('bamboo-leaves-container');
    if (!container) return;
    var count = 18;
    for (var i = 0; i < count; i++) {
      var petal = document.createElement('div');
      petal.className = 'petal';
      var size = 8 + Math.random() * 10;
      petal.style.width = size + 'px';
      petal.style.height = size + 'px';
      petal.style.left = Math.random() * 100 + '%';
      petal.style.animationDuration = (8 + Math.random() * 12) + 's';
      petal.style.animationDelay = (Math.random() * 20) + 's';
      petal.style.opacity = 0.3 + Math.random() * 0.3;
      var hue = 340 + Math.random() * 20;
      petal.style.background = 'radial-gradient(ellipse at 30% 30%, hsl(' + hue + ', 70%, 80%), hsl(' + hue + ', 60%, 65%))';
      container.appendChild(petal);
    }
  }

  // ===== 星空闪烁 =====
  function initStars() {
    var container = document.getElementById('stars-container');
    if (!container) return;
    var count = 80;
    for (var i = 0; i < count; i++) {
      var star = document.createElement('div');
      star.className = 'star';
      star.style.left = Math.random() * 100 + '%';
      star.style.top = Math.random() * 100 + '%';
      star.style.animationDuration = (2 + Math.random() * 4) + 's';
      star.style.animationDelay = (Math.random() * 5) + 's';
      container.appendChild(star);
    }
  }

  // ===== 滚动显现 =====
  function initReveal() {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale').forEach(function(el) {
      obs.observe(el);
    });
  }

  // ===== 鼠标光晕 - 水墨晕染效果 =====
  function initGlow() {
    var g = document.getElementById('mouse-glow');
    if (!g) return;
    var mx = -500, my = -500, cx = -500, cy = -500, raf = null;
    function tick() {
      cx += (mx - cx) * 0.05;
      cy += (my - cy) * 0.05;
      var dark = document.documentElement.classList.contains('dark');
      var c = dark ? 'rgba(247, 243, 232, 0.02)' : 'rgba(28, 28, 28, 0.025)';
      g.style.background = 'radial-gradient(350px circle at ' + cx + 'px ' + cy + 'px, ' + c + ', transparent 70%)';
      if (Math.abs(mx - cx) > 0.3 || Math.abs(my - cy) > 0.3) raf = requestAnimationFrame(tick);
      else raf = null;
    }
    document.addEventListener('mousemove', function(e) { mx = e.clientX; my = e.clientY; g.classList.add('active'); if (!raf) raf = requestAnimationFrame(tick); });
    document.addEventListener('mouseleave', function() { g.classList.remove('active'); if (raf) { cancelAnimationFrame(raf); raf = null; } });
  }

  // ===== 墨韵粒子系统 =====
  function initInk() {
    var canvas = document.getElementById('ink-canvas');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var W, H, particles = [], isDark = false, frame = null;

    function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }

    function create(count) {
      var p = [];
      // 墨点
      for (var i = 0; i < count; i++) {
        p.push({
          x: Math.random() * W, y: Math.random() * H,
          size: Math.random() * 2.5 + 0.5,
          vx: (Math.random() - 0.5) * 0.08,
          vy: -(Math.random() * 0.15 + 0.02),
          o: Math.random() * 0.1 + 0.03,
          phase: Math.random() * Math.PI * 2,
          speed: Math.random() * 0.01 + 0.002,
          type: 'drop'
        });
      }
      // 远山
      for (var i = 0; i < 4; i++) {
        p.push({
          x: Math.random() * W, y: H * 0.78 + Math.random() * H * 0.08,
          size: Math.random() * 120 + 60,
          o: Math.random() * 0.02 + 0.01,
          type: 'mountain'
        });
      }
      return p;
    }

    function drawDrop(p) {
      p.phase += p.speed;
      var o = p.o + Math.sin(p.phase) * 0.02;
      o = Math.max(0.02, Math.min(0.12, o));
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
      var dark = document.documentElement.classList.contains('dark');
      ctx.fillStyle = dark ? 'rgba(247, 243, 232, ' + o + ')' : 'rgba(28, 28, 28, ' + o + ')';
      ctx.fill();
    }

    function drawMtn(p) {
      ctx.beginPath();
      ctx.moveTo(p.x - p.size, p.y);
      ctx.quadraticCurveTo(p.x - p.size * 0.4, p.y - p.size * 0.7, p.x, p.y - p.size * 0.35);
      ctx.quadraticCurveTo(p.x + p.size * 0.4, p.y - p.size * 0.5, p.x + p.size, p.y);
      ctx.closePath();
      var dark = document.documentElement.classList.contains('dark');
      ctx.fillStyle = dark ? 'rgba(247, 243, 232, ' + p.o + ')' : 'rgba(28, 28, 28, ' + p.o + ')';
      ctx.fill();
    }

    function update(p) {
      p.x += p.vx; p.y += p.vy;
      if (p.y < -10) { p.y = H + 10; p.x = Math.random() * W; }
      if (p.x < -10) p.x = W + 10;
      if (p.x > W + 10) p.x = -10;
    }

    function loop() {
      ctx.clearRect(0, 0, W, H);
      for (var i = 0; i < particles.length; i++) {
        if (particles[i].type === 'mountain') drawMtn(particles[i]);
        else { update(particles[i]); drawDrop(particles[i]); }
      }
      frame = requestAnimationFrame(loop);
    }

    
  // ===== 雪花飘落 + 鼠标跟随 =====
  function initSnow() {
    var canvas = document.getElementById('snow-canvas');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var W, H, flakes = [], mouseX = -1000, mouseY = -1000, frame = null;

    function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }

    function createFlakes(count) {
      var f = [];
      for (var i = 0; i < count; i++) {
        f.push({
          x: Math.random() * W,
          y: Math.random() * H,
          r: Math.random() * 4 + 1,
          vx: (Math.random() - 0.5) * 0.3,
          vy: Math.random() * 0.5 + 0.2,
          o: Math.random() * 0.4 + 0.4,
          phase: Math.random() * Math.PI * 2,
          speed: Math.random() * 0.02 + 0.005
        });
      }
      return f;
    }

    function update() {
      for (var i = 0; i < flakes.length; i++) {
        var f = flakes[i];
        // 飘落
        f.phase += f.speed;
        f.x += f.vx + Math.sin(f.phase) * 0.2;
        f.y += f.vy;
        // 鼠标排斥 - 雪花远离鼠标
        var dx = f.x - mouseX;
        var dy = f.y - mouseY;
        var dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 100) {
          var force = (100 - dist) / 100 * 1.5;
          f.x += (dx / dist) * force;
          f.y += (dy / dist) * force;
        }
        // 边界重置
        if (f.y > H + 10) { f.y = -10; f.x = Math.random() * W; }
        if (f.x < -10) f.x = W + 10;
        if (f.x > W + 10) f.x = -10;
      }
    }

    function draw() {
      ctx.clearRect(0, 0, W, H);
      var dark = document.documentElement.classList.contains('dark');
      for (var i = 0; i < flakes.length; i++) {
        var f = flakes[i];
        ctx.beginPath();
        ctx.arc(f.x, f.y, f.r, 0, Math.PI * 2);
        if (dark) {
          ctx.fillStyle = 'rgba(247, 243, 232, ' + (f.o * 0.6) + ')';
        } else {
          ctx.fillStyle = 'rgba(255, 255, 255, ' + (f.o * 0.7) + ')';
        }
        ctx.fill();
      }
    }

    function loop() {
      update();
      draw();
      frame = requestAnimationFrame(loop);
    }

    document.addEventListener('mousemove', function(e) {
      mouseX = e.clientX;
      mouseY = e.clientY;
    });

    function init() {
      if (frame) { cancelAnimationFrame(frame); frame = null; }
      resize();
      flakes = createFlakes(40);
      loop();
    }

    init();
    window.addEventListener('resize', resize);
  }

  function init() {
      if (frame) { cancelAnimationFrame(frame); frame = null; }
      particles = []; resize();
      isDark = document.documentElement.classList.contains('dark');
      particles = create(isDark ? 12 : 20);
      loop();
    }

    var mo = new MutationObserver(function() {
      var nd = document.documentElement.classList.contains('dark');
      if (nd !== isDark) { isDark = nd; init(); }
    });
    mo.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
    window.addEventListener('resize', resize);
    init();
  }

  // ===== 自动应用显现 =====
  function autoReveal() {
    document.querySelectorAll('section, article, .card-ink, .reveal-auto').forEach(function(el) {
      if (!el.classList.contains('reveal') && !el.classList.contains('no-reveal') && el.offsetHeight > 40) {
        el.classList.add('reveal');
      }
    });
  }

  
  // ===== 雪花飘落 + 鼠标跟随 =====
  function initSnow() {
    var canvas = document.getElementById('snow-canvas');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var W, H, flakes = [], mouseX = -1000, mouseY = -1000, frame = null;

    function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }

    function createFlakes(count) {
      var f = [];
      for (var i = 0; i < count; i++) {
        f.push({
          x: Math.random() * W,
          y: Math.random() * H,
          r: Math.random() * 4 + 1,
          vx: (Math.random() - 0.5) * 0.3,
          vy: Math.random() * 0.5 + 0.2,
          o: Math.random() * 0.4 + 0.4,
          phase: Math.random() * Math.PI * 2,
          speed: Math.random() * 0.02 + 0.005
        });
      }
      return f;
    }

    function update() {
      for (var i = 0; i < flakes.length; i++) {
        var f = flakes[i];
        // 飘落
        f.phase += f.speed;
        f.x += f.vx + Math.sin(f.phase) * 0.2;
        f.y += f.vy;
        // 鼠标排斥 - 雪花远离鼠标
        var dx = f.x - mouseX;
        var dy = f.y - mouseY;
        var dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 100) {
          var force = (100 - dist) / 100 * 1.5;
          f.x += (dx / dist) * force;
          f.y += (dy / dist) * force;
        }
        // 边界重置
        if (f.y > H + 10) { f.y = -10; f.x = Math.random() * W; }
        if (f.x < -10) f.x = W + 10;
        if (f.x > W + 10) f.x = -10;
      }
    }

    function draw() {
      ctx.clearRect(0, 0, W, H);
      var dark = document.documentElement.classList.contains('dark');
      for (var i = 0; i < flakes.length; i++) {
        var f = flakes[i];
        ctx.beginPath();
        ctx.arc(f.x, f.y, f.r, 0, Math.PI * 2);
        if (dark) {
          ctx.fillStyle = 'rgba(247, 243, 232, ' + (f.o * 0.6) + ')';
        } else {
          ctx.fillStyle = 'rgba(255, 255, 255, ' + (f.o * 0.7) + ')';
        }
        ctx.fill();
      }
    }

    function loop() {
      update();
      draw();
      frame = requestAnimationFrame(loop);
    }

    document.addEventListener('mousemove', function(e) {
      mouseX = e.clientX;
      mouseY = e.clientY;
    });

    function init() {
      if (frame) { cancelAnimationFrame(frame); frame = null; }
      resize();
      flakes = createFlakes(40);
      loop();
    }

    init();
    window.addEventListener('resize', resize);
  }

  function init() {
    
    initStars(); initSnow();
    autoReveal();
    initReveal();
    initGlow();
    initInk();
  }

  // 支持 ViewTransitions 导航后重新初始化
  function runInit() {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  }
  runInit();
  document.addEventListener('astro:page-load', runInit);
})();
</script>












