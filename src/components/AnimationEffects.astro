---
// 水墨意境 - 动画与微交互系统（优化版）
// 星空闪烁 | 滚动显现 | 鼠标光晕 | 墨韵流动 | 雪花飘落
---

<style is:global>
  /* ===== 暗色模式星空 ===== */
  .stars-container {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    pointer-events: none; z-index: 0; overflow: hidden;
    opacity: 0; transition: opacity 1s ease;
  }
  .dark .stars-container { opacity: 1; }
  .stars-container .star {
    position: absolute; width: 2px; height: 2px; background: #fff;
    border-radius: 50%; animation: starTwinkle ease-in-out infinite alternate;
  }
  .stars-container .star:nth-child(odd) { width: 1.5px; height: 1.5px; }
  .stars-container .star:nth-child(3n) { width: 2.5px; height: 2.5px; }
  @keyframes starTwinkle {
    0% { opacity: 0.1; transform: scale(0.8); }
    100% { opacity: 0.8; transform: scale(1.2); }
  }
  /* ===== 笔触书写动画 ===== */
  .brush-stroke-anim { position: relative; display: inline-block; }
  .brush-stroke-anim::after {
    content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    background: linear-gradient(90deg, transparent 0%, var(--bg-primary) 50%, transparent 100%);
    animation: brushReveal 1.5s ease-out forwards;
  }
  @keyframes brushReveal {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }
  /* ===== 墨滴扩散 ===== */
  .ink-dot { position: absolute; width: 6px; height: 6px; background: var(--accent); border-radius: 50%; pointer-events: none; animation: inkSpread 1.2s ease-out forwards; }
  @keyframes inkSpread {
    0% { transform: scale(0); opacity: 0.8; }
    50% { opacity: 0.4; }
    100% { transform: scale(8); opacity: 0; }
  }
  /* ===== 卷轴展开 ===== */
  .scroll-unfold { animation: scrollUnfold 1.8s cubic-bezier(0.22, 1, 0.36, 1) forwards; overflow: hidden; }
  @keyframes scrollUnfold {
    0% { clip-path: inset(0 100% 0 0); }
    100% { clip-path: inset(0 0% 0 0); }
  }
  /* ===== Canvas ===== */
  #snow-canvas, #ink-canvas {
    position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
    pointer-events: none;
  }
  #snow-canvas { z-index: 1; }
  #ink-canvas { z-index: 0; opacity: 0.35; }
  .dark #ink-canvas { opacity: 0.15; }
  /* ===== 鼠标光晕 ===== */
  #mouse-glow {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    pointer-events: none; z-index: 0;
  }
</style>

<div class="stars-container" id="stars-container"></div>
<div id="mouse-glow"></div>
<canvas id="ink-canvas"></canvas>
<canvas id="snow-canvas"></canvas>

<script>
(function() {
  "use strict";

  // ===== 星空闪烁 =====
  function initStars() {
    var container = document.getElementById("stars-container");
    if (!container || container.hasChildNodes()) return;
    for (var i = 0; i < 80; i++) {
      var star = document.createElement("div");
      star.className = "star";
      star.style.left = Math.random() * 100 + "%";
      star.style.top = Math.random() * 100 + "%";
      star.style.animationDuration = (2 + Math.random() * 4) + "s";
      star.style.animationDelay = (Math.random() * 5) + "s";
      container.appendChild(star);
    }
  }

  // ===== 滚动显现 =====
  function initReveal() {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) {
          e.target.classList.add("visible");
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.08, rootMargin: "0px 0px -40px 0px" });
    document.querySelectorAll(".reveal, .reveal-left, .reveal-right, .reveal-scale").forEach(function(el) {
      obs.observe(el);
    });
  }

  // ===== 自动添加reveal =====
  function autoReveal() {
    document.querySelectorAll("section, article, .card-ink, .reveal-auto").forEach(function(el) {
      if (!el.classList.contains("reveal") && !el.classList.contains("no-reveal") && el.offsetHeight > 40) {
        el.classList.add("reveal");
      }
    });
  }

  // ===== 鼠标光晕 =====
  function initGlow() {
    var g = document.getElementById("mouse-glow");
    if (!g) return;
    var mx = -500, my = -500, cx = -500, cy = -500, raf = null;
    function tick() {
      cx += (mx - cx) * 0.05;
      cy += (my - cy) * 0.05;
      var dark = document.documentElement.classList.contains("dark");
      var c = dark ? "rgba(247, 243, 232, 0.02)" : "rgba(28, 28, 28, 0.025)";
      g.style.background = "radial-gradient(350px circle at " + cx + "px " + cy + "px, " + c + ", transparent 70%)";
      raf = requestAnimationFrame(tick);
    }
    document.addEventListener("mousemove", function(e) {
      mx = e.clientX; my = e.clientY;
      if (!raf) raf = requestAnimationFrame(tick);
    });
    document.addEventListener("mouseleave", function() {
      if (raf) { cancelAnimationFrame(raf); raf = null; }
    });
  }

  // ===== 墨韵流动 =====
  function initInk() {
    var canvas = document.getElementById("ink-canvas");
    if (!canvas) return;
    var ctx = canvas.getContext("2d");
    var W, H, particles = [], isDark = false, frame = null, running = false;

    function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }

    function create(count) {
      var p = [];
      for (var i = 0; i < count; i++) {
        p.push({
          x: Math.random() * W, y: Math.random() * H,
          size: Math.random() * 2.5 + 0.5,
          vx: (Math.random() - 0.5) * 0.05,
          vy: -(Math.random() * 0.1 + 0.02),
          alpha: Math.random() * 0.06 + 0.02,
          phase: Math.random() * Math.PI * 2,
          speed: Math.random() * 0.005 + 0.002
        });
      }
      return p;
    }

    function draw() {
      ctx.clearRect(0, 0, W, H);
      var time = Date.now() * 0.001;
      // 云雾
      for (var i = 0; i < 5; i++) {
        var mx = (Math.sin(time * 0.05 + i * 1.5) * 0.3 + 0.5) * W;
        var my = H * (0.2 + i * 0.12);
        var mw = 200 + Math.sin(time * 0.03 + i) * 80;
        var grad = ctx.createRadialGradient(mx, my, 0, mx, my, mw);
        grad.addColorStop(0, "rgba(28,28,28,0.03)");
        grad.addColorStop(1, "rgba(28,28,28,0)");
        ctx.fillStyle = grad;
        ctx.beginPath(); ctx.arc(mx, my, mw, 0, Math.PI * 2); ctx.fill();
      }
      // 粒子
      for (var i = 0; i < particles.length; i++) {
        var p = particles[i];
        p.phase += p.speed;
        p.x += p.vx; p.y += p.vy;
        if (p.y < -10) { p.y = H + 10; p.x = Math.random() * W; }
        if (p.x < -10) p.x = W + 10; if (p.x > W + 10) p.x = -10;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = "rgba(28,28,28," + (p.alpha + Math.sin(p.phase) * 0.015) + ")";
        ctx.fill();
      }
    }

    function loop() {
      draw();
      frame = requestAnimationFrame(loop);
    }

    function start() {
      if (running) return; running = true;
      resize();
      isDark = document.documentElement.classList.contains("dark");
      particles = create(isDark ? 12 : 20);
      loop();
    }

    function stop() {
      running = false;
      if (frame) { cancelAnimationFrame(frame); frame = null; }
    }

    // 切后台时暂停，不影响前台体验
    document.addEventListener("visibilitychange", function() {
      if (document.hidden) stop(); else start();
    });

    new MutationObserver(function() {
      var nd = document.documentElement.classList.contains("dark");
      if (nd !== isDark) { isDark = nd; stop(); start(); }
    }).observe(document.documentElement, { attributes: true, attributeFilter: ["class"] });

    window.addEventListener("resize", resize);
    start();
  }

  // ===== 雪花飘落 =====
  function initSnow() {
    var canvas = document.getElementById("snow-canvas");
    if (!canvas) return;
    var ctx = canvas.getContext("2d");
    var W, H, flakes = [], mouseX = -1000, mouseY = -1000, frame = null, running = false;

    function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }

    function createFlakes(count) {
      var f = [];
      for (var i = 0; i < count; i++) {
        f.push({
          x: Math.random() * W, y: Math.random() * H,
          r: Math.random() * 4 + 1,
          vx: (Math.random() - 0.5) * 0.3,
          vy: Math.random() * 0.5 + 0.2,
          o: Math.random() * 0.4 + 0.4,
          phase: Math.random() * Math.PI * 2,
          speed: Math.random() * 0.02 + 0.005
        });
      }
      return f;
    }

    function update() {
      for (var i = 0; i < flakes.length; i++) {
        var f = flakes[i];
        f.phase += f.speed;
        f.x += f.vx + Math.sin(f.phase) * 0.2;
        f.y += f.vy;
        var dx = f.x - mouseX, dy = f.y - mouseY, dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 100) {
          var force = (100 - dist) / 100 * 1.5;
          f.x += (dx / dist) * force; f.y += (dy / dist) * force;
        }
        if (f.y > H + 10) { f.y = -10; f.x = Math.random() * W; }
        if (f.x < -10) f.x = W + 10; if (f.x > W + 10) f.x = -10;
      }
    }

    function draw() {
      ctx.clearRect(0, 0, W, H);
      var dark = document.documentElement.classList.contains("dark");
      for (var i = 0; i < flakes.length; i++) {
        var f = flakes[i];
        ctx.beginPath(); ctx.arc(f.x, f.y, f.r, 0, Math.PI * 2);
        ctx.fillStyle = dark ? "rgba(247,243,232," + (f.o * 0.6) + ")" : "rgba(255,255,255," + (f.o * 0.7) + ")";
        ctx.fill();
      }
    }

    function loop() {
      update(); draw();
      frame = requestAnimationFrame(loop);
    }

    function start() {
      if (running) return; running = false;
      resize();
      flakes = createFlakes(40);
      loop();
    }

    function stop() {
      running = false;
      if (frame) { cancelAnimationFrame(frame); frame = null; }
    }

    document.addEventListener("mousemove", function(e) { mouseX = e.clientX; mouseY = e.clientY; });
    document.addEventListener("visibilitychange", function() {
      if (document.hidden) stop(); else start();
    });
    window.addEventListener("resize", resize);
    start();
  }

  // ===== 主初始化 =====
  function init() {
    initStars();
    autoReveal();
    initReveal();
    initGlow();
    // Canvas动画延迟启动，优先保证页面渲染
    setTimeout(function() { initInk(); }, 300);
    setTimeout(function() { initSnow(); }, 600);
  }

  function runInit() {
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  }
  runInit();
  document.addEventListener("astro:page-load", runInit);
})();
</script>
