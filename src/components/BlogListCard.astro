---
export interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  category: string;
  coverImage?: string;
  readingTime?: number;
  tags?: string[];
}

import { formatDate } from "../utils/date";

const { title, description, date, slug, category, coverImage, readingTime = 5, tags = [] } = Astro.props;
---

<a
  href={"/blog/" + slug}
  class="group flex flex-col md:flex-row gap-6 p-6 card-ink transition-all duration-300 hover:scale-[1.01] "
  style="background-color:var(--card-bg);border:1px solid var(--border)"
>
  {coverImage && (
    <div class="shrink-0 w-full md:w-48 h-32 rounded-xl overflow-hidden relative">
      <img
        src={coverImage}
        alt={title}
        class="w-full h-full object-cover transition-all duration-500 group-hover:scale-110" loading="lazy" decoding="async"
      />
      <span class="absolute top-2 right-2 inline-block px-2 py-0.5 text-xs rounded-md" style="background:var(--accent);color:#f7f3e8;font-family:'LXGW WenKai',serif;">
        {category}
      </span>
    </div>
  )}
  <div class="flex-1 min-w-0">
    <span class="inline-block px-2 py-0.5 text-xs mb-2 ink-btn rounded-sm" style="background-color:var(--accent-light);color:var(--bg-primary)">
      {category}
    </span>
    <h2 class="text-xl font-serif font-semibold mb-2 transition-colors duration-300 group-hover:text-gradient" style="color:var(--text-primary)">
      {title}
    </h2>
    <p class="text-sm leading-relaxed line-clamp-2 mb-3" style="color:var(--text-secondary)">
      {description}
    </p>
    <div class="flex items-center justify-between text-xs" style="color:var(--text-secondary)">
      <div class="flex items-center gap-3">
        <span class="relative-time" data-date={date.toISOString()}>{formatDate(date)}</span>
        <span>·</span>
        <span class="flex items-center gap-1">
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          {readingTime} 分
        </span>
      </div>
      {tags.length > 0 && (
        <div class="flex items-center gap-1.5">
          {tags.slice(0, 2).map(tag => (
            <span class="text-[10px] px-1.5 py-0.5 rounded-sm" style="background:var(--ink-light);color:var(--text-secondary);">#{tag}</span>
          ))}
        </div>
      )}
    </div>
  </div>
  <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-gradient-to-r from-transparent via-[var(--accent)] to-transparent scale-x-0 group-hover:scale-x-100 transition-transform duration-500" style="transform-origin:left;"></div>
</a>

