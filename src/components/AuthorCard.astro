---
import profile from "../data/profile.json";
---

<div class="card-ink p-6 reveal">
  <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6">
    <div class="shrink-0">
      <div class="author-avatar">
        <img
          src={profile.avatar}
          alt={profile.name}
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
    <div class="min-w-0 flex-1 text-center sm:text-left">
      <h3 class="text-lg font-serif font-bold" style="color:var(--text-primary)">{profile.name}</h3>
      <p class="text-xs mt-1.5 leading-relaxed" style="color:var(--text-secondary); font-family: 'LXGW WenKai', serif;">
        {profile.bio.split("\n").map(line => <>{line}<br /></>)}
      </p>
      <p class="text-xs mt-2 leading-relaxed" style="color:var(--text-secondary); opacity:0.7; font-family: 'LXGW WenKai', serif;">
        {profile.subBio}
      </p>
      <div class="flex items-center justify-center sm:justify-start gap-4 mt-3">
        <a href={"https://github.com/" + profile.github} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-xs transition-all duration-300 hover:scale-110 hover:text-gradient" style="color:var(--text-secondary)" aria-label="GitHub">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          <span>GitHub</span>
        </a>
        <a href={"mailto:" + profile.email} class="inline-flex items-center gap-1.5 text-xs transition-all duration-300 hover:scale-110 hover:text-gradient" style="color:var(--text-secondary)" aria-label="Email">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <span>邮件</span>
        </a>
      </div>
    </div>
  </div>
</div>

<style is:global>
  .author-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--accent);
    flex-shrink: 0;
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    opacity: 0.95;
    position: relative;
  }
  .author-avatar::after {
    content: "";
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1px solid rgba(199, 62, 58, 0.2);
    animation: pulse-glow 3s ease-in-out infinite;
  }
  .author-avatar:hover {
    transform: scale(1.08);
    box-shadow: 0 0 24px rgba(199, 62, 58, 0.2);
  }
  @media (max-width: 640px) {
    .author-avatar {
      width: 72px;
      height: 72px;
    }
  }
</style>
